---
import Site from '../layouts/Site.astro';
import '../styles/pages.css';
---

<Site
  title="Check Your Email — Practitioner Notes"
  description="One more step to subscribe to Practitioner Notes from Purple Directive."
>
  <section class="prod-hero" style="text-align:center">
    <div class="container">
      <div class="section-label" style="color:#cbb8ff">Almost there</div>
      <h1 style="margin-left:auto;margin-right:auto">Check your inbox to <span style="color:#b69bff">confirm</span></h1>
      <p class="lede" style="margin-left:auto;margin-right:auto">
        We just sent you an email with a confirmation link. Click the link to
        finish subscribing to <strong style="color:#fff">Practitioner Notes</strong> — monthly
        observations from inside FDA-regulated clinical research operations.
      </p>
      <p class="lede" style="margin:1rem auto 0;font-size:0.92rem">
        Didn't get the email? Check your spam folder, then add
        <code style="font-family:var(--font-mono);font-size:0.88rem;background:rgba(124,58,237,0.14);padding:0.1em 0.35em;border-radius:4px;color:#cbb8ff">practitioner-notes@mail.beehiiv.com</code> to your contacts so
        future issues land in your inbox. If it still hasn't arrived in 5
        minutes, email <a href="mailto:info@purpledirective.com" style="color:#cbb8ff;font-weight:500">info@purpledirective.com</a>.
      </p>
      <div class="cta-row" style="justify-content:center;margin-top:2rem">
        <a href="/" class="btn-ghost">Back to Home</a>
      </div>
    </div>
  </section>
</Site>
