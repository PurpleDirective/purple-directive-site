  "description": "An honest comparison of Nexrial CTMS and Florence Healthcare for clinical research sites. Florence is a site enablement platform focused on eTMF, eISF (eBinders), eConsent, and remote monitoring. Nexrial is a full CTMS for independent sites covering study management, visit scheduling, invoicing, delegation logs, and native Part 11 e-signature.",
  "brand": {
    "@type": "Organization",
    "name": "Purple Directive"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is Florence Healthcare?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Florence Healthcare is a clinical trial site enablement platform offering eBinders (eISF / electronic Investigator Site File), eConsent (digital informed consent workflows), SiteLink (document exchange and remote monitoring for sponsors/CROs), and eTMF (Electronic Trial Master File). Florence serves approximately 65,000 study sites across 90+ countries and describes itself as the #1 rated platform for research sites. It is not a full CTMS — it does not natively cover visit scheduling, budget tracking, monitoring visit findings, or protocol deviation logs as primary features."
