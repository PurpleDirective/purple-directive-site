---
import Site from '../layouts/Site.astro';
import '../styles/pages.css';
---

<Site title="Thank You" description="Your purchase is complete. Thank you for choosing Purple Directive.">
  <section class="prod-hero" style="text-align:center">
    <div class="container">
      <div class="section-label" style="color:#cbb8ff">Order complete</div>
      <h1 style="margin-left:auto;margin-right:auto">Thank you for your <span style="color:#b69bff">purchase</span></h1>
      <p class="lede" style="margin-left:auto;margin-right:auto">
        Your SOP Template Bundle is on its way. You'll receive a download link at the email address you used during checkout.
      </p>
      <p class="lede" style="margin:1rem auto 0">
        If you have any questions or need help customizing your templates, reach out at
        <a href="mailto:info@purpledirective.com" style="color:#cbb8ff;font-weight:500">info@purpledirective.com</a>.
      </p>
      <div class="cta-row" style="justify-content:center;margin-top:2rem">
        <a href="/" class="btn-ghost">Back to Home</a>
      </div>
    </div>
  </section>
</Site>
