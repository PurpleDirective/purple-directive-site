---
import Site from '../layouts/Site.astro';
---
<Site
  title="Home"
  description="The standard clinical research runs on. Software, SOPs, and infrastructure for the people who run the studies — one operating standard, from your first protocol to your fiftieth."
>
  <!-- HERO -->
  <section class="hero">
    <div class="atmos" aria-hidden="true"></div>
    <div class="container">
      <div class="hero-copy">
        <span class="eyebrow"><span class="pip"></span>Clinical Research Operations</span>
        <h1 class="head"><span class="ln">The Standard</span><span class="ln soft">clinical research</span><span class="ln"><span class="accent">runs on.</span></span></h1>
        <p class="sub">Software, SOPs, and infrastructure for the people who run the studies &mdash; <b>one operating standard</b>, from your first protocol to your fiftieth.</p>
        <div class="cta-row">
          <a href="#products" class="btn-primary">Explore the products
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          <a href="/sop-bundle" class="btn-ghost">Get the SOP bundle &mdash; $249.99</a>
        </div>
      </div>

      <div class="hub-wrap">
        <div class="hub" id="hub" role="img" aria-label="Purple Directive's portfolio: a central practice with seven instruments — Nexrial, the SOP Library, Research Reports, PurpleSign, QuillPDF, Volstrin, and Consulting — orbiting one standard in three dimensions.">
          <div class="hub-inner" id="hubInner">
            <canvas id="hubCanvas" aria-hidden="true"></canvas>
            <div class="core-pulse" id="corePulse" aria-hidden="true"></div>
            <div class="core" aria-hidden="true">
              <img src="/pd-mark-grad.svg" alt="" aria-hidden="true" width="50" height="60" />
            </div>
            <div id="nodes"></div>
          </div>
          <div class="ledger-box" aria-hidden="true">
            <div class="ledger-cap"><span class="lp"></span>Append-only ledger</div>
            <ul id="ledger"></ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE STANDARD — audit-trail act -->
  <section class="audit" id="standard">
    <div class="container">
      <div class="section-label audit-label">The Standard, visible</div>
      <h2 class="audit-h2">An audit trail that can't be undone.</h2>
      <p class="audit-lede">Every record keeps who, what, when, and why &mdash; <b>appended, never overwritten</b>. This is what "designed against 21 CFR Part 11" actually looks like.</p>
      <div class="trail" id="trail">
        <div class="trail-rail"><div class="trail-fill" id="trailFill"></div></div>
        <ol class="cps">
          <li class="cp"><span class="cp-dot"></span><div class="cp-card"><span class="cp-k">Source</span><span class="cp-t">Source document captured</span><span class="cp-m">09:42:01 &middot; reyes</span></div></li>
          <li class="cp"><span class="cp-dot"></span><div class="cp-card"><span class="cp-k">Entry</span><span class="cp-t">Data point recorded</span><span class="cp-m">09:42:18 &middot; park</span></div></li>
          <li class="cp"><span class="cp-dot"></span><div class="cp-card"><span class="cp-k">Signature</span><span class="cp-t">Signature applied</span><span class="cp-m">09:43:05 &middot; osei</span></div></li>
          <li class="cp"><span class="cp-dot"></span><div class="cp-card"><span class="cp-k">Audit</span><span class="cp-t">Audit entry logged</span><span class="cp-m">09:43:05 &middot; system</span></div></li>
          <li class="cp"><span class="cp-dot"></span><div class="cp-card"><span class="cp-k">Locked</span><span class="cp-t">Record locked</span><span class="cp-m">09:43:06 &middot; system</span></div></li>
        </ol>
      </div>
    </div>
  </section>

  <!-- SEVEN INSTRUMENTS — products -->
  <section class="section" id="products">
    <div class="container">
      <div class="section-label">The Portfolio</div>
      <h2>Seven instruments. One standard.</h2>
      <p class="lede">From day-one SOP templates to trial-management software &mdash; every product built to the same bar, so the rigor never drops when you move between tools.</p>
      <div class="inst-grid">
        <a class="inst" href="https://nexrial.com" target="_blank" rel="noopener">
          <div class="inst-top"><span class="inst-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></span><span class="ik">Software</span></div>
          <h3>Nexrial <span class="arr">&rarr;</span></h3><p>Clinical trial management with a 21 CFR Part 11 audit trail and role-based access.</p></a>
        <a class="inst" href="/sop-bundle">
          <div class="inst-top"><span class="inst-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 2 7l10 5 10-5-10-5Z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/></svg></span><span class="ik">Templates</span></div>
          <h3>SOP Library <span class="arr">&rarr;</span></h3><p>13 ICH-GCP standard operating procedures across the full study lifecycle.</p></a>
        <a class="inst" href="/research-report">
          <div class="inst-top"><span class="inst-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3v18h18"/><rect x="7" y="11" width="3" height="6" rx=".6"/><rect x="12" y="7" width="3" height="10" rx=".6"/><rect x="17" y="13" width="3" height="4" rx=".6"/></svg></span><span class="ik">Research</span></div>
          <h3>Research Report <span class="arr">&rarr;</span></h3><p>Analyst-grade healthcare market reports, delivered in 48 hours.</p></a>
        <a class="inst" href="https://purplesign.app" target="_blank" rel="noopener">
          <div class="inst-top"><span class="inst-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5Z"/></svg></span><span class="ik">E-signature</span><span class="tag tag-soon">Soon</span></div>
          <h3>PurpleSign <span class="arr">&rarr;</span></h3><p>Electronic signatures, designed against 21 CFR Part 11 controls.</p></a>
        <a class="inst" href="https://quillpdf.com" target="_blank" rel="noopener">
          <div class="inst-top"><span class="inst-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg></span><span class="ik">Tools</span><span class="tag tag-free">Free</span></div>
          <h3>QuillPDF <span class="arr">&rarr;</span></h3><p>PDF tools that run in your browser &mdash; free, with redaction that stays client-side.</p></a>
        <a class="inst" href="https://volstrin.com" target="_blank" rel="noopener">
          <div class="inst-top"><span class="inst-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span><span class="ik">Recruiting</span></div>
          <h3>Volstrin <span class="arr">&rarr;</span></h3><p>Specialist recruiting for the legal sector &mdash; an adjacent regulated field.</p></a>
        <a class="inst inst-wide" href="/consulting">
          <div class="inst-wide-head">
            <div class="inst-top"><span class="inst-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 18v-5a9 9 0 0 1 18 0v5"/><path d="M21 19a2 2 0 0 1-2 2h-1a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h3Z"/><path d="M3 19a2 2 0 0 0 2 2h1a1 1 0 0 0 1-1v-3a1 1 0 0 0-1-1H3Z"/></svg></span><span class="ik">Services</span></div>
            <h3>Consulting &mdash; regulatory infrastructure, hands-on <span class="arr">&rarr;</span></h3>
          </div>
          <p>SOP development, binder setup, IRB submission support, and compliance gap assessments &mdash; the same operators, on call.</p></a>
      </div>
    </div>
  </section>

  <!-- FREE SOP — lead magnet -->
  <section class="section freebar" style="padding-top:0">
    <div class="container">
      <div class="freebar-card">
        <div class="freebar-copy">
          <div class="section-label">Free to start</div>
          <h2>Read a full SOP, free.</h2>
          <p>SOP-01 &mdash; Training &amp; Qualification of Study Staff &mdash; published in full. Read the whole procedure on the page and download it in editable Word and PDF, no signup. It's one of the 13 in the bundle, so you can judge the quality before you buy.</p>
        </div>
        <div class="freebar-cta">
          <a href="/training-qualification-sop" class="btn-primary">Read the free SOP
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          <a href="/sop-bundle" class="btn-ghost">See the full bundle</a>
        </div>
      </div>
    </div>
  </section>

  <!-- OPERATORS — about -->
  <section class="section" id="about" style="padding-top:0">
    <div class="container">
      <div class="section-label">Operators, not vendors</div>
      <div class="band-split">
        <div><h2>Built so a small team operates like a large one.</h2></div>
        <div>
          <p>Purple Directive isn't a software shop that wandered into clinical research. The people here have sat through the monitoring visits, built the binders, and answered to the inspector &mdash; so the tools assume the work you actually do.</p>
          <p>And because one company builds all of it, the pieces fit: the SOPs line up with the trial system, the signatures line up with the audit trail. One stack, one standard, one company accountable for all of it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROOF -->
  <section class="proof" id="proof">
    <div class="container">
      <span class="pl">Built for inspection</span>
      <span class="pchip">ICH E6(R3)-aligned</span>
      <span class="pchip">Implements 21 CFR Part 11 controls</span>
      <span class="pchip">HIPAA BAA available</span>
      <span class="pchip">Phase I&ndash;IV experience</span>
      <span class="pchip">Your data exports anytime</span>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-tail">
    <div class="container">
      <h2>Hold your studies to The Standard.</h2>
      <p>Start with the SOP bundle, or talk to us about the software and consulting behind it.</p>
      <div class="cta-row">
        <a href="#products" class="btn-primary">Explore the products</a>
        <a href="mailto:info@purpledirective.com" class="btn-ghost">Contact us</a>
      </div>
    </div>
  </section>

  <!-- Baseline: build nodes + ledger. Works even if WebGL / module fails. -->
  <script is:inline>
  (function(){
    window.__INSTR=[
      {name:'Nexrial', line:'Clinical trial management · Part 11 audit trail'},
      {name:'SOP Library', line:'13 ICH-GCP standard operating procedures'},
      {name:'Research Report', line:'Analyst-grade market reports in 48 hours'},
      {name:'PurpleSign', line:'E-signatures, designed against 21 CFR Part 11'},
      {name:'QuillPDF', line:'Free, in-browser PDF tools'},
      {name:'Volstrin', line:'Specialist legal-sector recruiting'},
      {name:'Consulting', line:'Regulatory infrastructure, hands-on'}
    ];
    window.__EVENTS=['Source document verified','Audit entry logged','Signature applied','Consent recorded','Monitoring visit closed','Record locked','Deviation resolved','Query answered'];
    window.__hover=-1;
    var nodesLayer=document.getElementById('nodes'), hub=document.getElementById('hub'), ledger=document.getElementById('ledger');
    if(!nodesLayer||!hub||!ledger) return;
    window.__nodes=window.__INSTR.map(function(it,i){
      var a=document.createElement('a'); a.href='#products'; a.className='node';
      a.setAttribute('aria-label', it.name+' — '+it.line);
      a.innerHTML='<span class="dot"></span><span class="nm">'+it.name+'</span><span class="chip">'+it.line+'</span>';
      (function(idx){
        function en(){window.__hover=idx;} function lv(){if(window.__hover===idx)window.__hover=-1;}
        a.addEventListener('mouseenter',en); a.addEventListener('mouseleave',lv);
        a.addEventListener('focus',en); a.addEventListener('blur',lv);
      })(i);
      nodesLayer.appendChild(a);
      return {el:a, it:it};
    });
    window.__ringLayout=function(){
      var r=hub.getBoundingClientRect(), cx=r.width/2, cy=r.height/2, R=Math.min(r.width,r.height)*0.33;
      window.__nodes.forEach(function(n,i){ var a=(-Math.PI/2)+(i/window.__nodes.length)*Math.PI*2;
        n.el.style.transform='translate('+(cx+Math.cos(a)*R)+'px,'+(cy+Math.sin(a)*R)+'px) translate(-50%,-50%)'; });
    };
    window.__ringLayout();
    window.addEventListener('resize', function(){ if(!window.__hub3d) window.__ringLayout(); });
    window.__stamp=function(ev){ var li=document.createElement('li'); var d=new Date(), p=function(n){return ('0'+n).slice(-2);};
      li.innerHTML='<span class="t">'+p(d.getHours())+':'+p(d.getMinutes())+':'+p(d.getSeconds())+'</span><span class="ar">&#9656;</span><span class="ev">'+ev+'</span>';
      ledger.insertBefore(li, ledger.firstChild); while(ledger.children.length>5) ledger.removeChild(ledger.lastChild); };
    window.__stamp(window.__EVENTS[2]); window.__stamp(window.__EVENTS[1]); window.__stamp(window.__EVENTS[0]);
  })();
  </script>

  <!-- 3D enhancement: Three.js (bundled, same-origin). If WebGL fails, baseline ring remains. -->
  <script>
  import * as THREE from 'three';
  (function(){
    var reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var hub=document.getElementById('hub'), canvas=document.getElementById('hubCanvas');
    var corePulse=document.getElementById('corePulse'), ledger=document.getElementById('ledger');
    var nodes=window.__nodes||[], EVENTS=window.__EVENTS;
    if(!hub||!canvas||!ledger||!nodes.length) return;
    var renderer;
    try{ renderer=new THREE.WebGLRenderer({canvas:canvas, alpha:true, antialias:true}); }catch(e){ return; }
    renderer.setPixelRatio(Math.min(window.devicePixelRatio||1,2));
    renderer.setClearColor(0x000000,0);
    window.__hub3d=true;
    var scene=new THREE.Scene();
    var camera=new THREE.PerspectiveCamera(42,1,0.1,100); camera.position.set(0,0,6);
    var tilt=new THREE.Group(); scene.add(tilt);
    var ring=new THREE.Group(); tilt.add(ring);
    var R=1.96, N=nodes.length;

    nodes.forEach(function(n,i){
      var ang=(-Math.PI/2)+(i/N)*Math.PI*2;
      var anchor=new THREE.Object3D(); anchor.position.set(Math.cos(ang)*R, Math.sin(ang)*R, 0); ring.add(anchor); n.anchor=anchor;
      var geo=new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(0,0,0), anchor.position.clone()]);
      var mat=new THREE.LineBasicMaterial({color:0x7C3AED, transparent:true, opacity:0.16});
      ring.add(new THREE.Line(geo,mat)); n.lineMat=mat;
    });

    function glowTex(){ var c=document.createElement('canvas'); c.width=c.height=128; var g=c.getContext('2d');
      var grd=g.createRadialGradient(64,64,0,64,64,64); grd.addColorStop(0,'rgba(170,130,255,0.95)'); grd.addColorStop(0.35,'rgba(124,58,237,0.42)'); grd.addColorStop(1,'rgba(124,58,237,0)');
      g.fillStyle=grd; g.fillRect(0,0,128,128); return new THREE.CanvasTexture(c); }
    var glow=glowTex();
    var core=new THREE.Sprite(new THREE.SpriteMaterial({map:glow, transparent:true, opacity:0.85, blending:THREE.AdditiveBlending, depthWrite:false}));
    core.scale.set(2.2,2.2,1); scene.add(core);

    var PN=42, pos=new Float32Array(PN*3);
    for(var i=0;i<PN;i++){ var a=i/PN*Math.PI*2, rr=R*1.55+(i%4)*0.12; pos[i*3]=Math.cos(a)*rr; pos[i*3+1]=Math.sin(a)*rr; pos[i*3+2]=Math.sin(i*1.7)*0.55; }
    var pg=new THREE.BufferGeometry(); pg.setAttribute('position', new THREE.BufferAttribute(pos,3));
    ring.add(new THREE.Points(pg, new THREE.PointsMaterial({color:0x7C3AED, size:0.05, transparent:true, opacity:0.55, blending:THREE.AdditiveBlending, depthWrite:false})));

    var packet=new THREE.Sprite(new THREE.SpriteMaterial({map:glow, transparent:true, opacity:0.95, blending:THREE.AdditiveBlending, depthWrite:false}));
    packet.scale.set(0.5,0.5,1); packet.visible=false; ring.add(packet);
    var pkFrom=new THREE.Vector3(), pkT=-1, pkEv='', lastSpawn=0;

    var W=1,Hh=1;
    function resize(){ var r=hub.getBoundingClientRect(); W=r.width; Hh=r.height; renderer.setSize(W,Hh,false); camera.aspect=W/Hh; camera.updateProjectionMatrix(); }
    resize(); window.addEventListener('resize', resize);

    var tpx=0,tpy=0,px=0,py=0;
    if(!reduce){
      hub.addEventListener('pointermove', function(e){ var r=hub.getBoundingClientRect(); tpx=((e.clientX-r.left)/r.width-0.5); tpy=((e.clientY-r.top)/r.height-0.5); });
      hub.addEventListener('pointerleave', function(){ tpx=0; tpy=0; });
    }
    function corePop(){ corePulse.classList.remove('go'); void corePulse.offsetWidth; corePulse.classList.add('go'); }
    function stamp(ev){ var li=document.createElement('li'); var d=new Date(), p=function(n){return ('0'+n).slice(-2);};
      li.innerHTML='<span class="t">'+p(d.getHours())+':'+p(d.getMinutes())+':'+p(d.getSeconds())+'</span><span class="ar">&#9656;</span><span class="ev">'+ev+'</span>';
      ledger.insertBefore(li, ledger.firstChild); while(ledger.children.length>5) ledger.removeChild(ledger.lastChild); }
    ledger.innerHTML=''; if(reduce){ stamp(EVENTS[2]); stamp(EVENTS[1]); stamp(EVENTS[0]); } else { stamp(EVENTS[0]); }

    var wp=new THREE.Vector3(), v=new THREE.Vector3();
    function project(){
      var hover=window.__hover;
      for(var i=0;i<nodes.length;i++){
        var n=nodes[i];
        n.anchor.getWorldPosition(wp); v.copy(wp).project(camera);
        var x=(v.x*0.5+0.5)*W, y=(-v.y*0.5+0.5)*Hh;
        var df=Math.max(0,Math.min(1,(wp.z+3.0)/6.0));
        var sc=0.82+0.36*df, op=0.6+0.4*df;
        n.el.style.transform='translate('+x.toFixed(1)+'px,'+y.toFixed(1)+'px) translate(-50%,-50%) scale('+sc.toFixed(3)+')';
        n.el.style.opacity=op.toFixed(2);
        n.el.style.zIndex=String(Math.round(df*20));
        var on=(hover===i);
        n.lineMat.color.setHex(on?0xb69bff:0x7C3AED);
        n.lineMat.opacity=on?0.95:0.16;
      }
    }

    var last=0, raf=0;
    function frame(t){
      var dt=Math.min(50,t-last); last=t;
      if(!reduce) ring.rotation.z += 0.00007*dt;
      px+=(tpx-px)*0.06; py+=(tpy-py)*0.06;
      tilt.rotation.y = px*0.55; tilt.rotation.x = -0.5 + py*0.28;
      if(!reduce){
        var br=1+Math.sin(t*0.0011)*0.045; core.scale.set(2.2*br,2.2*br,1); core.material.opacity=0.74+Math.sin(t*0.0011)*0.1;
        if(pkT<0 && t-lastSpawn>2800){ var idx=Math.floor(t*0.013)%PN; pkFrom.set(pos[idx*3],pos[idx*3+1],pos[idx*3+2]); packet.position.copy(pkFrom); packet.visible=true; packet.material.opacity=0; packet.scale.setScalar(0.5); pkT=0; pkEv=EVENTS[idx%EVENTS.length]; lastSpawn=t; }
        else if(pkT>=0){ pkT+=dt/1900; var k=Math.min(1,pkT); var e=k*k*(3-2*k); packet.position.set(pkFrom.x*(1-e), pkFrom.y*(1-e), pkFrom.z*(1-e)); packet.material.opacity=0.95*Math.sin(k*Math.PI); packet.scale.setScalar(0.52-0.22*k); if(pkT>=1){ packet.visible=false; pkT=-1; stamp(pkEv); corePop(); } }
      }
      project();
      renderer.render(scene,camera);
      raf=requestAnimationFrame(frame);
    }

    if(reduce){ tilt.rotation.x=-0.42; project(); renderer.render(scene,camera); }
    else if('IntersectionObserver' in window){
      new IntersectionObserver(function(es){ es.forEach(function(en){
        if(en.isIntersecting){ if(!raf){ last=performance.now(); raf=requestAnimationFrame(frame); } }
        else if(raf){ cancelAnimationFrame(raf); raf=0; }
      }); },{threshold:0.02}).observe(hub);
    } else { raf=requestAnimationFrame(frame); }
  })();
  </script>

  <!-- GSAP motion layer (bundled, same-origin; graceful under reduced-motion) -->
  <script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  (function(){
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if(reduce) return;
    var g = gsap;
    g.registerPlugin(ScrollTrigger);
    var REVEAL=['.eyebrow','.head .ln','.sub','.cta-row','.hub-wrap'];
    var tl = g.timeline({defaults:{ease:'power3.out'}, onComplete:function(){ g.set(REVEAL,{clearProps:'transform'}); }})
      .from('.eyebrow',{y:16,opacity:0,duration:.6})
      .from('.head .ln',{yPercent:42,opacity:0,duration:.8,stagger:.12},'-=.2')
      .from('.sub',{y:16,opacity:0,duration:.6},'-=.4')
      .from('.cta-row',{y:16,opacity:0,duration:.5},'-=.35')
      .from('.hub-wrap',{opacity:0,scale:.92,duration:1.1,ease:'power2.out'},'-=.95');
    function settle(){ try{ if(tl.progress()<1) tl.progress(1); g.set(REVEAL,{opacity:1,clearProps:'transform'}); }catch(e){} }
    setTimeout(settle, 2600);
    document.addEventListener('visibilitychange', function(){ if(!document.hidden) settle(); });
    function reveal(sel,extra){ g.utils.toArray(sel).forEach(function(el){ g.from(el, Object.assign({y:26,opacity:0,duration:.7,ease:'power3.out',scrollTrigger:{trigger:el,start:'top 84%'}}, extra||{})); }); }
    reveal('.band-split h2'); reveal('.band-split p');
    reveal('.audit-h2'); reveal('.audit-lede');
    g.timeline({scrollTrigger:{trigger:'#standard', start:'top 68%', toggleActions:'play none none none'}, defaults:{ease:'power2.out'}})
      .fromTo('#trailFill',{width:'0%'},{width:'100%',duration:2.0,ease:'none'},0)
      .from('.audit .cp',{opacity:0,y:12,duration:.5,stagger:.38},0.2);
    // Instrument cards reveal via IntersectionObserver, not ScrollTrigger: IO keys
    // off real intersection (firing even for cards already in view on a deep-link
    // load), so a jump straight to #products can never strand them hidden.
    var instCards = g.utils.toArray('.inst');
    if('IntersectionObserver' in window){
      instCards.forEach(function(el){ el.style.opacity='0'; el.style.transform='translateY(28px)'; el.style.transition='opacity .55s ease, transform .55s ease'; });
      var io = new IntersectionObserver(function(ents){
        ents.forEach(function(e){ if(e.isIntersecting){ var el=e.target; el.style.opacity='1'; el.style.transform='none'; io.unobserve(el); } });
      }, {rootMargin:'0px 0px -6% 0px'});
      instCards.forEach(function(el){ io.observe(el); });
    }
    g.from('.proof .pchip',{y:12,opacity:0,duration:.45,stagger:.06,ease:'power2.out',scrollTrigger:{trigger:'.proof',start:'top 88%'}});
    reveal('.cta-tail h2'); reveal('.cta-tail p');

    // Safety net: a deep-link jump to #products lands the grid in view before the
    // hero intro settles, so ScrollTrigger caches stale start positions and the
    // .from() reveals never fire — leaving cards stuck hidden. Refresh once layout
    // settles, and on deep-link loads force-reveal any card already on screen.
    var STUCK=['.band-split h2','.band-split p','.audit-h2','.audit-lede','.proof .pchip','.cta-tail h2','.cta-tail p'];
    function rescueInView(){
      g.utils.toArray(STUCK.join(',')).forEach(function(el){
        var r=el.getBoundingClientRect();
        if(r.top<window.innerHeight*0.98 && r.bottom>0 && parseFloat(getComputedStyle(el).opacity)<0.99){
          g.set(el,{opacity:1,clearProps:'transform'});
        }
      });
    }
    function refresh(){ try{ ScrollTrigger.refresh(); }catch(e){} }
    window.addEventListener('load', refresh);
    setTimeout(function(){ refresh(); rescueInView(); }, 700);
    setTimeout(function(){ refresh(); rescueInView(); }, 2700);
    // On a deep-link load, reveals may already be compromised — guarantee any card
    // scrolled into view becomes visible (pristine top-down animation is unaffected).
    if(location.hash && location.hash.length>1){
      var ticking=false;
      window.addEventListener('scroll', function(){
        if(ticking) return; ticking=true;
        requestAnimationFrame(function(){ rescueInView(); ticking=false; });
      }, {passive:true});
    }
  })();
  </script>
