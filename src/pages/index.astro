---
import Base from '../layouts/Base.astro';
---

<Base title="Home" activePage="home" description="Purple Directive — compliance-grade software and operations consulting for clinical research sites and CROs. SOP templates, CTMS, and regulatory infrastructure.">

  <!-- Hero -->
  <section class="hero">
    <p class="tagline">Clinical Research Operations</p>
    <h1>Purple<span class="accent">Directive</span></h1>
    <p class="subtitle">
      Compliance-grade software and operations consulting for sponsors, CROs, and research sites.
      SOPs, CTMS, regulatory infrastructure — built from real site operations across Phase I–IV studies.
    </p>
    <div class="hero-cta">
      <a href="#products" class="btn-primary">View Products</a>
      <a href="/hire" class="btn-secondary">Work With Us</a>
    </div>
  </section>

  <!-- Trust Indicators -->
  <section class="trust-bar">
    <div class="trust-item">
      <span class="trust-num">ICH E6(R2/R3)</span>
      <span class="trust-label">GCP Aligned</span>
    </div>
    <div class="trust-item">
      <span class="trust-num">21 CFR Part 11</span>
      <span class="trust-label">Audit Trail</span>
    </div>
    <div class="trust-item">
      <span class="trust-num">Phase I–IV</span>
      <span class="trust-label">Active Studies</span>
    </div>
    <div class="trust-item">
      <span class="trust-num">FDA Ready</span>
      <span class="trust-label">Inspection Prepared</span>
    </div>
  </section>

  <!-- Products — split layout -->
  <section class="section" id="products">
    <div class="split-layout">
      <div class="split-left">
        <h2>Products</h2>
        <p class="split-desc">Ready-to-use tools for clinical research operations — from day-one compliance templates to full trial management software.</p>
        <div class="split-stats">
          <div class="split-stat">
            <span class="split-stat-num">12</span>
            <span class="split-stat-label">SOPs</span>
          </div>
          <div class="split-stat">
            <span class="split-stat-num">11</span>
            <span class="split-stat-label">Forms</span>
          </div>
          <div class="split-stat">
            <span class="split-stat-num">95+</span>
            <span class="split-stat-label">Pages</span>
          </div>
        </div>
      </div>
      <div class="split-right">
        <div class="card product-card featured-card">
          <div class="popular-badge">Most Popular</div>
          <div class="card-label">Templates</div>
          <h3>SOP Template Bundle</h3>
          <p>
            12 ICH E6(R2/R3)-aligned Standard Operating Procedures covering the full
            study lifecycle — from staff training and site start-up through data management,
            adverse events, monitoring, and close-out.
          </p>
          <div class="product-meta">
            <span class="price">$249.99</span>
            <span class="price-note">PDF + Word</span>
          </div>
          <a href="/sop-bundle" class="btn-primary btn-sm">View the Bundle</a>
        </div>

        <div class="card product-card">
          <div class="card-label">Software</div>
          <h3>Nexrial CTMS</h3>
          <p>
            Clinical Trial Management System with 21 CFR Part 11 audit trail,
            role-based access control, encrypted backups, and multi-tenant architecture.
          </p>
          <div class="product-meta">
            <span class="price">Contact</span>
            <span class="price-note">Custom deployment</span>
          </div>
          <a href="https://nexrial.com" class="btn-secondary btn-sm" target="_blank" rel="noopener">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- What's in the SOPs — split: sidebar + table -->
  <section class="section section-tinted">
    <div class="sop-split">
      <div class="sop-sidebar">
        <h2>What's in the Bundle</h2>
        <p>Each SOP is built on ICH E6(R2) with E6(R3) guidance notes, referencing 21 CFR Parts 11/50/56/312 and 45 CFR Part 46.</p>
        <p class="sop-lifecycle">Ordered by study lifecycle — from first training record to final close-out.</p>

        <div class="bundle-extras-stacked">
          <div class="extra-item">
            <span class="extra-icon">&#128196;</span>
            <div>
              <strong>Editable Word files</strong>
              <span>Branded PDF + customizable .docx</span>
            </div>
          </div>
          <div class="extra-item">
            <span class="extra-icon">&#9745;</span>
            <div>
              <strong>11 companion forms</strong>
              <span>Training logs, checklists, tracking templates</span>
            </div>
          </div>
          <div class="extra-item">
            <span class="extra-icon">&#9998;</span>
            <div>
              <strong>PI signature lines</strong>
              <span>Approval sections on every SOP</span>
            </div>
          </div>
        </div>

        <a href="/sop-bundle" class="btn-primary btn-sm" style="margin-top: var(--spacing-md);">Get the Bundle — $249.99</a>
      </div>

      <div class="sop-table-wrap">
        <table class="sop-table">
          <thead>
            <tr>
              <th>SOP</th>
              <th>Title</th>
              <th>Key Coverage</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><span class="sop-num">001</span></td>
              <td>Training & Qualification</td>
              <td>GCP training, DOA log, competency assessment</td>
            </tr>
            <tr>
              <td><span class="sop-num">002</span></td>
              <td>Essential Documents</td>
              <td>12-tab binder, ICH E6 Sections 8.2-8.4, eTMF</td>
            </tr>
            <tr>
              <td><span class="sop-num">003</span></td>
              <td>Study Start-Up</td>
              <td>Feasibility, CDA/NDA, budget, 1572, SIV prep</td>
            </tr>
            <tr>
              <td><span class="sop-num">004</span></td>
              <td>Informed Consent</td>
              <td>20 ICH elements, eConsent, vulnerable populations</td>
            </tr>
            <tr>
              <td><span class="sop-num">005</span></td>
              <td>Recruitment & Retention</td>
              <td>10 active + 8 passive methods, compensation</td>
            </tr>
            <tr>
              <td><span class="sop-num">006</span></td>
              <td>IP Management</td>
              <td>Receipt, dispensing, unblinding, DEA compliance</td>
            </tr>
            <tr>
              <td><span class="sop-num">007</span></td>
              <td>Data Management</td>
              <td>ALCOA+, source docs, 21 CFR Part 11</td>
            </tr>
            <tr>
              <td><span class="sop-num">008</span></td>
              <td>AE & Deviations</td>
              <td>SAE reporting timelines, CAPA procedures</td>
            </tr>
            <tr>
              <td><span class="sop-num">009</span></td>
              <td>QC / QA</td>
              <td>QA framework, Quality by Design, CtQ factors</td>
            </tr>
            <tr>
              <td><span class="sop-num">010</span></td>
              <td>Monitoring Visits</td>
              <td>SQV, SIV, routine, close-out checklists</td>
            </tr>
            <tr>
              <td><span class="sop-num">011</span></td>
              <td>Remote Monitoring</td>
              <td>Platform security, PHI, hybrid visits</td>
            </tr>
            <tr>
              <td><span class="sop-num">012</span></td>
              <td>Study Close-Out</td>
              <td>DB lock, IP reconciliation, archival</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section section-deep">
    <div class="section-header">
      <h2>Services</h2>
      <p>Consulting and engineering for clinical research operations.</p>
    </div>

    <div class="card-grid card-grid-3">
      <div class="card">
        <div class="card-label">Consulting</div>
        <h3>Regulatory Infrastructure</h3>
        <p>
          SOP development, regulatory binder setup, IRB submission support,
          and compliance gap assessments for new and existing sites.
        </p>
      </div>

      <div class="card">
        <div class="card-label">Software</div>
        <h3>Compliance-Grade Development</h3>
        <p>
          Custom software with audit trails, RBAC, encrypted storage,
          and regulatory documentation. HIPAA and 21 CFR Part 11 aligned.
        </p>
      </div>

      <div class="card">
        <div class="card-label">Automation</div>
        <h3>Site Operations Automation</h3>
        <p>
          Workflow automation, document generation, data pipelines,
          and reporting tools that reduce manual overhead for research coordinators.
        </p>
      </div>
    </div>
  </section>

  <!-- Who We Serve — bento grid -->
  <section class="section section-tinted">
    <div class="section-header">
      <h2>Who We Work With</h2>
    </div>

    <div class="bento-grid">
      <div class="audience-item bento-feature">
        <div class="bento-icon">&#127973;</div>
        <h3>Sponsors</h3>
        <p>Pharmaceutical and biotech companies qualifying sites, evaluating CRO operations, or sourcing audit-ready compliance documentation for their study portfolios.</p>
      </div>
      <div class="audience-item">
        <div class="bento-icon">&#128200;</div>
        <h3>CROs</h3>
        <p>Contract research organizations updating SOP libraries or standardizing multi-site operations.</p>
      </div>
      <div class="audience-item">
        <div class="bento-icon">&#127975;</div>
        <h3>Research Sites</h3>
        <p>Sites building compliance infrastructure from the ground up or preparing for their first study.</p>
      </div>
      <div class="audience-item">
        <div class="bento-icon">&#128300;</div>
        <h3>Principal Investigators</h3>
        <p>PIs establishing compliance infrastructure for sponsor-initiated or investigator-initiated studies.</p>
      </div>
      <div class="audience-item">
        <div class="bento-icon">&#128188;</div>
        <h3>Consultants &amp; Individuals</h3>
        <p>Independent professionals who need ready-to-use templates for client engagements or career development.</p>
      </div>
    </div>
  </section>

  <!-- CTA (dark) -->
  <section class="cta-dark">
    <h2>Ready to get your site operational?</h2>
    <p>Download the SOP bundle today, or reach out to discuss custom consulting and software.</p>
    <div class="hero-cta">
      <a href="/sop-bundle" class="btn-primary">View the SOP Bundle — $249.99</a>
      <a href="mailto:info@purpledirective.com" class="btn-secondary btn-on-dark">Contact Us</a>
    </div>
  </section>

</Base>

<style>
  /* ── Buttons ── */
  .hero-cta {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    margin-top: var(--spacing-lg);
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    background: var(--purple-primary);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    background: var(--purple-dark);
    color: #fff;
    transform: translateY(-1px);
  }

  .btn-secondary {
    display: inline-block;
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--purple-primary);
    color: var(--purple-primary);
  }

  .btn-on-dark { color: #9ca3af; border-color: #374151; }
  .btn-on-dark:hover { color: #e5e7eb; border-color: #6b7280; }
  .btn-sm { font-size: 0.82rem; padding: 0.55rem 1rem; margin-top: var(--spacing-sm); }

  /* ── Trust bar ── */
  .trust-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-md);
    padding: var(--spacing-lg) var(--spacing-xl);
    border-top: 3px solid var(--purple-primary);
    border-bottom: 1px solid var(--border);
    background: var(--bg-card);
    border-radius: 0 0 10px 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .trust-item { text-align: center; display: flex; flex-direction: column; gap: 0.2rem; }
  .trust-num { font-size: 1rem; font-weight: 700; color: var(--purple-primary); }
  .trust-label { font-size: 0.7rem; font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; }

  /* ── Split layout (Products) ── */
  .split-layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--spacing-xl);
    align-items: start;
  }

  .split-left h2 {
    margin-top: 0;
    font-size: 1.75rem;
  }

  .split-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .split-stats {
    display: flex;
    gap: var(--spacing-lg);
    margin-top: var(--spacing-lg);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--border);
  }

  .split-stat {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .split-stat-num {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--purple-primary);
    line-height: 1;
  }

  .split-stat-label {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .split-right {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  /* ── Product cards ── */
  .product-card { display: flex; flex-direction: column; }
  .product-card p { flex: 1; }

  .featured-card {
    border-color: var(--purple-primary);
    border-width: 2px;
    position: relative;
  }

  .featured-card:hover {
    border-color: var(--purple-primary);
    box-shadow: 0 8px 24px rgba(91, 33, 182, 0.14);
    transform: translateY(-3px);
  }

  .popular-badge {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    background: var(--purple-primary);
    padding: 0.3rem 0.75rem;
    border-radius: 4px;
    margin-bottom: var(--spacing-sm);
    width: fit-content;
  }

  .product-meta { display: flex; align-items: baseline; gap: var(--spacing-sm); margin: var(--spacing-sm) 0; }
  .price { font-size: 1.25rem; font-weight: 700; color: var(--purple-primary); }
  .price-orig { font-size: 0.9rem; color: var(--text-muted); text-decoration: line-through; }
  .price-note { font-size: 0.72rem; color: var(--text-muted); }

  /* ── SOP split layout ── */
  .sop-split {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: var(--spacing-xl);
    align-items: start;
  }

  .sop-sidebar h2 {
    margin-top: 0;
    font-size: 1.5rem;
  }

  .sop-sidebar p {
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .sop-lifecycle {
    color: var(--purple-primary);
    font-weight: 500;
    font-size: 0.85rem !important;
  }

  .bundle-extras-stacked {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--border);
  }

  .extra-item { display: flex; gap: var(--spacing-sm); align-items: flex-start; }
  .extra-icon { font-size: 1.2rem; line-height: 1.4; flex-shrink: 0; }
  .extra-item strong { display: block; font-size: 0.85rem; color: var(--text-primary); margin-bottom: 0.15rem; }
  .extra-item span { font-size: 0.78rem; color: var(--text-secondary); line-height: 1.4; }

  /* SOP table */
  .sop-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg-card);
    margin: 0;
  }

  .sop-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  .sop-table thead { background: var(--bg-card); }
  .sop-table th {
    font-size: 0.68rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.06em; color: var(--text-muted); text-align: left;
    padding: 0.65rem 0.85rem; border-bottom: 2px solid var(--border);
  }
  .sop-table td { padding: 0.55rem 0.85rem; color: var(--text-secondary); border-bottom: 1px solid var(--border); }
  .sop-table tr:last-child td { border-bottom: none; }
  .sop-table tr:hover td { background: var(--purple-glow); }
  .sop-num { font-weight: 700; color: var(--purple-primary); font-size: 0.78rem; }

  /* ── 3-column card grid (Services) ── */
  .card-grid-3 { grid-template-columns: repeat(3, 1fr); }

  /* ── Bento grid (Who We Work With) ── */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: var(--spacing-md);
    margin: var(--spacing-lg) 0;
  }

  .bento-feature {
    grid-row: 1 / 3;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--purple-primary) !important;
    border-color: var(--purple-primary) !important;
    color: #fff;
  }

  .bento-feature h3 { color: #fff; }
  .bento-feature p { color: rgba(255,255,255,0.85); }
  .bento-feature .bento-icon { font-size: 2rem; }

  .audience-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: var(--spacing-lg);
    transition: border-color 0.2s, transform 0.2s;
  }

  .audience-item:not(.bento-feature):hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .bento-icon {
    font-size: 1.5rem;
    margin-bottom: var(--spacing-sm);
  }

  .audience-item h3 { margin-top: 0; font-size: 1rem; margin-bottom: var(--spacing-xs); }
  .audience-item p { font-size: 0.85rem; margin-bottom: 0; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .split-layout {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .split-stats {
      justify-content: flex-start;
    }

    .sop-split {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .trust-bar {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-lg);
    }

    .card-grid-3 {
      grid-template-columns: 1fr;
    }

    .bento-grid {
      grid-template-columns: 1fr 1fr;
    }

    .bento-feature {
      grid-column: 1 / -1;
      grid-row: auto;
    }
  }

  @media (max-width: 480px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }

    .trust-bar { grid-template-columns: 1fr; text-align: left; }
    .trust-item { flex-direction: row; align-items: center; gap: var(--spacing-sm); text-align: left; }

    .hero-cta { flex-direction: column; align-items: stretch; }
    .btn-primary, .btn-secondary { text-align: center; }
  }
</style>
