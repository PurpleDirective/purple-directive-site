<style>
  /* =============================================
     Product page — distinct from landing page
     ============================================= */

  /* Product top — no centered hero, no tagline label */
  .product-top {
    padding-top: var(--spacing-xl);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--border);
  }

  .product-hero {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--spacing-xl);
    align-items: start;
  }

  .product-hero-text {
    padding-top: var(--spacing-sm);
  }

  .product-badge {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--purple-primary);
    background: var(--purple-tint);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    margin-bottom: var(--spacing-md);
  }

  .product-hero-text h1 {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.02em;
  }

  .product-tagline {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: var(--spacing-lg);
    max-width: 500px;
  }

  .product-price-row {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-md);
  }

  .product-price {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
  }

  .product-price-note {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .buy-btn {
    display: inline-block;
    background: var(--purple-primary);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 600;
    padding: 0.85rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    width: 100%;
    text-align: center;
    max-width: 300px;
  }

  .buy-btn:hover {
    background: var(--purple-dark);
    color: #fff;
    transform: translateY(-1px);
  }

  .buy-note {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: var(--spacing-sm);
    margin-bottom: 0;
  }

  .product-hero-preview {
    background: var(--bg-tinted);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: var(--spacing-md);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-hero-preview img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }

  /* Stats — inline horizontal, minimal */
  .product-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    padding-top: var(--spacing-lg);
  }

  .stat {
    font-size: 0.82rem;
    color: var(--text-secondary);
  }

  .stat strong {
    color: var(--text-primary);
    font-weight: 700;
  }

  .stat-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--text-muted);
    flex-shrink: 0;
  }

  /* Preview strip — horizontal, not grid cards */
  .preview-section {
    padding: var(--spacing-xl) 0;
  }

  .preview-heading {
    font-size: 1.15rem;
    margin-top: 0;
    margin-bottom: var(--spacing-xs);
  }

  .preview-sub {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: var(--spacing-lg);
  }

  .preview-strip {
    display: flex;
    gap: var(--spacing-lg);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: var(--spacing-sm);
  }

  .preview-fig {
    flex: 0 0 260px;
    scroll-snap-align: start;
    margin: 0;
  }

  .preview-img-frame {
    background: var(--bg-tinted);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: var(--spacing-sm);
    margin-bottom: var(--spacing-sm);
  }

  .preview-img-frame img {
    width: 100%;
    height: auto;
    border-radius: 3px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06);
  }

  .preview-fig figcaption {
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .preview-fig figcaption strong {
    color: var(--purple-primary);
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
  }

  /* Included section — two-column layout */
  .included-section {
    padding: var(--spacing-xl) 0;
    border-top: 1px solid var(--border);
  }

  .included-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--spacing-xl);
    align-items: start;
  }

  .included-list h2 {
    font-size: 1.15rem;
    margin-top: 0;
    margin-bottom: var(--spacing-lg);
  }

  .list-group-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin: var(--spacing-lg) 0 var(--spacing-md) 0;
    padding-bottom: var(--spacing-xs);
    border-bottom: 1px solid var(--border);
  }

  .list-group-label:first-of-type {
    margin-top: 0;
  }

  .sop-list {
    list-style: none;
    counter-reset: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
  }

  .sop-list li {
    display: flex;
    gap: var(--spacing-md);
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--border);
    align-items: baseline;
  }

  .sop-list li:last-child {
    border-bottom: none;
  }

  .sop-id {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--purple-primary);
    flex-shrink: 0;
    width: 56px;
    letter-spacing: 0.02em;
  }

  .sop-list li strong {
    display: block;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.1rem;
  }

  .sop-list li span {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .companion-note {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  /* Sticky buy sidebar */
  .buy-sidebar {
    position: sticky;
    top: 80px;
  }

  .buy-card {
