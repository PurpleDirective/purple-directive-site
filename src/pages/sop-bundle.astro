        <h3 class="list-group-label">Companion Forms</h3>
        <p class="companion-note">11 checklists, training logs, and tracking templates — each in both fillable PDF and editable Word.</p>
      </div>

      <!-- Sticky buy sidebar -->
      <aside class="buy-sidebar">
        <div class="buy-card">
          <div class="buy-card-price">
