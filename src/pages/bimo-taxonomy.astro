          <tr><td>VAI (Voluntary Action Indicated)</td><td>87</td><td>136</td><td><em>Not published</em></td></tr>
          <tr><td>OAI (Official Action Indicated)</td><td>9</td><td>9</td><td><em>Not published</em></td></tr>
          <tr><td>Warning letters following BIMO</td><td>~6</td><td>~11</td><td>~12</td></tr>
