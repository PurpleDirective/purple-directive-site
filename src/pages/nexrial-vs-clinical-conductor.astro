  "description": "An honest comparison of Nexrial CTMS and Clinical Conductor (Advarra) for independent clinical research sites and small site networks. Both are CTMS platforms — this page covers how they differ on pricing transparency, target buyer, and operational scope.",
  "brand": {
    "@type": "Organization",
    "name": "Purple Directive"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is Clinical Conductor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Clinical Conductor is a CTMS (Clinical Trial Management System) originally developed for research sites and site networks. It was acquired by Advarra and is now part of Advarra's broader portfolio of clinical trial technology (which also includes OnCore, eReg, and eSource). Clinical Conductor targets site networks, health systems, and independent sites with a focus on financial management, patient recruitment, and research portfolio reporting."
      }
    },
    {
      "@type": "Question",
      "name": "How does Nexrial pricing compare to Clinical Conductor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nexrial publishes pricing transparently: $299/month Core, $599/month Pro, and a Founding Site Program at 50% off for life for the first 3–5 sites ($149 Core / $299 Pro). Clinical Conductor pricing is not publicly listed — Advarra directs all pricing inquiries to their sales team. Based on industry reporting, Clinical Conductor has historically been positioned in the $100–$800/month range depending on modules, but you should contact Advarra directly for current pricing."
      }
    },
    {
      "@type": "Question",
      "name": "Is Clinical Conductor or Nexrial better for a small independent site?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on size and budget. Clinical Conductor's Advarra backing means enterprise infrastructure — ISO 27001, SOC 2, and EHR integrations — which is a meaningful advantage for large health systems. For an independent site running 5–25 concurrent studies with a sub-$700/month CTMS budget, Nexrial's published pricing and purpose-built compliance architecture (delegation log with PI e-sig, immutable audit trail, IRB tracking, monitoring-visit workflow) are often a better fit without the enterprise overhead."
      }
    },
    {
      "@type": "Question",
      "name": "Does Clinical Conductor support 21 CFR Part 11?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Clinical Conductor, as part of Advarra's ISO 27001 and SOC 2 Type 2 certified infrastructure, includes audit trail and e-signature capabilities consistent with 21 CFR Part 11 requirements. Nexrial's Part 11 approach uses three independent database-level defenses (UPDATE, DELETE, and TRUNCATE revoked at the DB user level) with a full validation package (VAL-PLAN, IQ/OQ/PQ, VAL-REPORT) available under NDA."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
