---
import Base from '../layouts/Base.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Healthcare Market Research Report",
  "url": "https://purpledirective.com/research-report/",
  "description": "Custom healthcare and life-sciences market research report, 20-30 pages with primary-source citations, delivered in 48 hours by a named clinical research professional. Lower-priced than traditional syndicated research firms.",
  "brand": {
    "@type": "Organization",
    "name": "Purple Directive LLC",
    "url": "https://purpledirective.com"
  },
  "offers": {
    "@type": "Offer",
    "price": "750",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "url": "https://purpledirective.com/research-report/"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Why is the Purple Directive Healthcare Market Research Report priced at $750?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Syndicated healthcare reports from major firms like MarketsandMarkets, Mordor Intelligence, and Fortune Business Insights are priced $4,490 to $4,950 per report. IBISWorld full reports are $2,850. I deliver a custom, primary-source 20-30 page report, written specifically for the buyer's question rather than pulled from a shelf, for $750."
      }
    },
    {
      "@type": "Question",
      "name": "How does a $750 custom report compare to syndicated market research?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Syndicated reports (IBISWorld, MarketsandMarkets, Mordor, Fortune Business Insights) are pre-written for mass markets and delivered instantly from inventory. They are not customized to a specific buyer's question. I write each report specifically for the buyer's brief within 48 hours, with primary-source citations on every claim and upfront AI-use disclosure."
      }
    },
    {
      "@type": "Question",
      "name": "Is AI-assisted market research reliable?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "I disclose AI use upfront. AI tools handle retrieval and first-draft synthesis. I independently verify every primary source, cross-check every regulatory claim against the primary text, and sign every deliverable. As of April 2026, none of the major syndicated research firms publicly disclose their AI methodology on product pages or FAQs."
      }
    },
    {
      "@type": "Question",
      "name": "What about McKinsey, Bain, BCG, or specialty consulting firms for healthcare research?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "MBB firms run multi-month strategy engagements, not standalone market research reports. Specialty life-sciences consulting firms (Halloran, Trinity, ZS, L.E.K.) price custom healthcare engagements at $15,000 and up, typically delivered over 4-8 weeks. Purple Directive is a fit when you need a cited, structured research deliverable within 48 hours for under $1,000 — not a full strategy engagement."
      }
    },
    {
      "@type": "Question",
      "name": "What is a reasonable turnaround time for custom healthcare market research?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Custom consulting engagements typically run 4-8 weeks. Syndicated research reports deliver instantly from inventory but are not customized to your question. I deliver a custom, cited 20-30 page report within 48 hours of intake — enabled by AI-assisted retrieval and first-draft synthesis, combined with human verification. The 48-hour turnaround assumes a focused research question (single therapeutic area or specific competitive question)."
      }
    }
  ]
};
---

<Base
  title="How Purple Directive Compares — Healthcare Market Research"
  activePage="products"
  description="How Purple Directive's $750 48-hour custom healthcare market research compares to Frost & Sullivan, MarketsandMarkets, IBISWorld, Mordor Intelligence, Fortune Business Insights, Grand View Research, and traditional consulting firms. Verified April 2026 pricing with primary sources."
>

  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero: two-column, matching the rest of the product pages -->
  <div class="product-top">
    <div class="product-hero">
      <div class="product-hero-text">
        <span class="product-badge">Pricing Comparison · Verified April 2026</span>
        <h1>How Purple Directive Compares</h1>
        <p class="product-tagline">
          How my $750 custom 48-hour healthcare market research sits next to Frost &amp; Sullivan,
          MarketsandMarkets, IBISWorld, Mordor Intelligence, Fortune Business Insights,
          Grand View Research, and traditional consulting firms. I verified every price against each
          provider's public pricing page in April 2026 — if you find an error, email <a href="mailto:info@purpledirective.com">info@purpledirective.com</a>.
        </p>
        <a href="/research-report/" class="buy-btn">See Pricing &amp; Scope</a>
        <p class="buy-note">
          Not ready to order? <a href="/sample-report/">Read the public 1-page sample first</a>.
        </p>
      </div>
      <div class="product-hero-preview">
        <div>
          <p style="margin: 0 0 0.5rem; font-weight: 600; text-align: center;">At a glance</p>
          <ul style="list-style: none; padding: 0; margin: 0; font-size: 0.85rem; line-height: 1.8;">
            <li><strong>$750</strong> vs $2,850–$4,950 syndicated</li>
            <li><strong>48 hrs</strong> custom turnaround</li>
            <li><strong>Named</strong> author signature</li>
            <li><strong>AI use</strong> disclosed upfront</li>
          </ul>
        </div>
      </div>
    </div>
    <div class="product-stats">
      <div class="stat"><strong>$750</strong> flat</div>
      <div class="stat-sep"></div>
      <div class="stat"><strong>48 hrs</strong> custom</div>
      <div class="stat-sep"></div>
      <div class="stat">vs <strong>$2,850–$4,950</strong> syndicated</div>
      <div class="stat-sep"></div>
      <div class="stat"><strong>Verified</strong> April 2026</div>
    </div>
  </div>

  <!-- Comparison Table -->
  <section class="why-now-section">
    <h2>Pricing at a glance</h2>
    <div class="compare-table-wrap">
      <table class="compare-table">
        <thead>
          <tr>
            <th scope="col">Provider</th>
            <th scope="col">Price</th>
            <th scope="col">Turnaround</th>
            <th scope="col">Custom</th>
            <th scope="col">Named author</th>
            <th scope="col">AI disclosed*</th>
          </tr>
        </thead>
        <tbody>
          <tr class="compare-row-highlight">
            <td><strong>Purple Directive</strong></td>
            <td><strong>$750</strong></td>
            <td>48 hours (custom)</td>
            <td>Yes</td>
            <td>Yes</td>
            <td>Yes</td>
          </tr>
          <tr>
            <td>IBISWorld (Full Report)</td>
            <td>$2,850</td>
            <td>Instant*</td>
            <td>No</td>
            <td>No</td>
            <td>No</td>
          </tr>
          <tr>
            <td>IBISWorld (Spotlight, 10–20 pages)</td>
            <td>$800</td>
            <td>Instant*</td>
            <td>No</td>
            <td>No</td>
            <td>No</td>
          </tr>
          <tr>
            <td>ResearchAndMarkets</td>
            <td>$4,490</td>
            <td>Instant*</td>
            <td>No</td>
            <td>No</td>
            <td>No</td>
          </tr>
          <tr>
            <td>Mordor Intelligence</td>
            <td>$4,750</td>
            <td>Instant*</td>
            <td>No</td>
            <td>No</td>
            <td>No</td>
          </tr>
          <tr>
            <td>Fortune Business Insights</td>
            <td>$4,850</td>
            <td>Instant*</td>
            <td>No</td>
            <td>Yes (analyst listed)</td>
            <td>No</td>
          </tr>
          <tr>
            <td>MarketsandMarkets</td>
            <td>$4,950</td>
            <td>Instant*</td>
            <td>No</td>
            <td>No</td>
            <td>No</td>
          </tr>
          <tr>
            <td>Frost &amp; Sullivan (via MarketResearch.com)</td>
            <td>$2,450–$6,450</td>
            <td>Instant*</td>
            <td>No</td>
            <td>No</td>
            <td>No</td>
          </tr>
          <tr>
            <td>Grand View Research</td>
            <td>On request</td>
            <td>2–48 hrs*</td>
            <td>No</td>
            <td>No</td>
            <td>No</td>
          </tr>
          <tr>
            <td>Specialty consulting (Halloran, Trinity, ZS, L.E.K.)</td>
            <td>$15,000+</td>
            <td>4–8 weeks</td>
            <td>Yes</td>
            <td>Yes</td>
            <td>No</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="compare-note">
      <em>*<strong>"Custom"</strong> means written specifically for the buyer's question vs. pre-written for a mass market.
      <strong>"Instant"</strong> means a pre-written syndicated report is downloaded after purchase — not custom research.
      <strong>"AI disclosed"</strong> = whether the provider publicly states AI use in methodology, verified April 2026.</em>
    </p>
  </section>

  <!-- The Positioning -->
  <section class="why-now-section">
    <h2>Where Purple Directive sits in the market</h2>
    <div class="why-now-grid">
      <div class="why-now-card">
        <h3>Price</h3>
        <p>
          Syndicated healthcare reports from MarketsandMarkets, Mordor Intelligence, Fortune Business Insights,
          and ResearchAndMarkets are priced $4,490–$4,950. Purple Directive is $750 — roughly 15–17%
          of what those firms charge for a single-user license.
        </p>
      </div>
      <div class="why-now-card">
        <h3>Custom, not shelf</h3>
        <p>
          Syndicated reports are pre-written for mass markets. They are delivered "instantly" because
          they already exist. I write each report specifically for the buyer's question — within 48 hours of intake.
        </p>
      </div>
      <div class="why-now-card">
        <h3>AI disclosure</h3>
        <p>
          As of April 2026, none of the major syndicated firms publicly disclose their AI methodology
          on product pages or FAQs. I disclose it upfront — AI handles retrieval and first-draft synthesis;
          I verify sources, cross-check regulatory claims against primary text, and sign the deliverable.
        </p>
      </div>
      <div class="why-now-card">
        <h3>Named author</h3>
        <p>
          I'm the author. I work on FDA-regulated oncology studies at a US academic health system —
          in personal capacity, not representing any employer. That's the credential on every report.
          Most syndicated reports are produced by anonymous analyst teams.
        </p>
      </div>
    </div>
  </section>

  <!-- When NOT to buy us -->
  <section class="why-now-section">
    <h2>When a different provider is the better fit</h2>
    <div class="why-now-grid">
      <div class="why-now-card">
        <h3>You need a 150-page data-dense overview</h3>
        <p>
          If the goal is an encyclopedic pre-built industry report with extensive data tables,
          Fortune Business Insights or MarketsandMarkets will outdeliver a 20-30 page custom report on raw volume.
          I build focused answers, not coverage at scale — that's a different product shape.
        </p>
      </div>
      <div class="why-now-card">
        <h3>You need a full strategy engagement</h3>
        <p>
          If the scope is a multi-phase strategy project with primary research interviews, workshops,
          and stakeholder alignment — Halloran, Trinity, ZS, L.E.K., or similar specialty firms at $15,000+
          over 4–8 weeks is the right shape. My service is a research deliverable, not a consulting engagement.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="why-now-section cta-tinted">
    <h2>Ready to order?</h2>
    <p style="max-width: 640px; margin: 0 auto 1.5rem;">
      $750 flat. 48 hours. Primary-source citations. Written and signed by a clinical research professional.
    </p>
    <a href="/research-report/" class="buy-btn">See Full Scope &amp; Order</a>
    <p style="margin-top: 1rem; font-size: 0.9rem;">
      Want a free sample first? Read the <a href="/sample-report/">public 1-page sample</a> —
      a pattern read of FDA 483 observations at US oncology trial sites.
    </p>
    <p style="margin-top: 0.5rem; font-size: 0.9rem;">
      Not sure if this is right for you? <a href="https://calendly.com/nexrial/healthcare-market-research-scoping-call" rel="noopener">Book a 15-minute scoping call</a>.
    </p>
  </section>

  <!-- Sources -->
  <section class="why-now-section">
    <h2>Sources (verified April 2026)</h2>
    <ol class="citations-list">
      <li><a href="https://help.ibisworld.com/en/articles/8119074-how-much-does-it-cost-to-purchase-one-report" rel="noopener nofollow">IBISWorld — Report Pricing Help Center</a></li>
      <li><a href="https://www.marketsandmarkets.com/Market-Reports/wearables-pharma-biotech-market-99537956.html" rel="noopener nofollow">MarketsandMarkets — live product page</a></li>
      <li><a href="https://www.mordorintelligence.com/industry-reports/global-healthcare-it-market-industry" rel="noopener nofollow">Mordor Intelligence — live product page</a></li>
      <li><a href="https://www.fortunebusinessinsights.com/faq" rel="noopener nofollow">Fortune Business Insights — FAQ</a></li>
      <li><a href="https://www.researchandmarkets.com/reports/5781185/healthcare-services-market-report" rel="noopener nofollow">ResearchAndMarkets — live product page</a></li>
      <li><a href="https://www.grandviewresearch.com/info/faqs" rel="noopener nofollow">Grand View Research — FAQ</a></li>
      <li><a href="https://store.frost.com/industries/healthcare.html" rel="noopener nofollow">Frost &amp; Sullivan — healthcare store</a></li>
    </ol>
    <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 1.5rem;">
      <strong>Last verified:</strong> 2026-04-15. Pricing changes — if you spot a stale number, email <a href="mailto:info@purpledirective.com">info@purpledirective.com</a> and I'll re-verify.
    </p>
  </section>

  <!-- Final CTA strip — catches the bottom-scroll buyer -->
  <section class="why-now-section" style="text-align: center; padding-bottom: var(--spacing-lg);">
    <p style="font-size: 0.95rem; color: var(--text-secondary); margin-bottom: 1rem;">
      <strong>Ready when you are.</strong> $750 flat, 48 hours, primary-source citations.
    </p>
    <a href="https://buy.stripe.com/cNiaEX6aX5JTaD0gUR3gk0j" class="buy-btn" style="max-width: 360px;">Order a Report on Stripe</a>
  </section>

</Base>
