---
import Site from '../layouts/Site.astro';
import '../styles/pages.css';
import EmailCapture from '../components/EmailCapture.astro';
import Testimonials from '../components/Testimonials.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Clinical Research SOP Template Bundle",
  "url": "https://purpledirective.com/sop-bundle/",
  "description": "13 ICH E6(R2/R3)-aligned Standard Operating Procedures for clinical research sites, with 11 companion forms. Editable Word + PDF. Lower-priced than traditional SOP consulting engagements.",
  "brand": {
    "@type": "Organization",
    "name": "Purple Directive"
  },
  "offers": {
    "@type": "Offer",
    "price": "249.99",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "url": "https://purpledirective.com/sop-bundle/"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Why are Purple Directive SOP templates priced at $249.99 for the full bundle?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Custom SOP consulting for a clinical research site typically costs $5,000 to $15,000 for a full 12-document library from firms like Advarra, Halloran, or WCG. Site-specific software platforms (Medidata, Veeva Vault QMS, MasterControl) run $10,000 to $100,000+ per year. The Purple Directive bundle is a starting-point library — 13 ICH E6(R3)-aligned templates that a site adapts to its own operations. $249.99 full bundle or $29 per individual SOP."
      }
    },
    {
      "@type": "Question",
      "name": "Which SOPs are in the bundle?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Thirteen core procedures: SOP-001 Training & Qualification, SOP-002 Essential Documents, SOP-003 Study Start-Up & Feasibility, SOP-004 Informed Consent, SOP-005 Recruitment & Retention, SOP-006 Investigational Product Management, SOP-007 Data Management & Documentation, SOP-008 Adverse Events & Protocol Deviations, SOP-009 Quality Control & Assurance, SOP-010 Sponsor Interactions, SOP-011 Remote Monitoring Visits, SOP-012 Study Close-Out, SOP-013 HIPAA Authorization for Use and Disclosure of PHI in Research. Plus 11 companion forms."
      }
    },
    {
      "@type": "Question",
      "name": "Are these SOPs ready to use as-is?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "They are templates, not turnkey documents. Every SOP template contains customizable placeholders (site name, PI name, IRB of record, specific contact information, local regulatory context). Sites adapt each template to their own operations, review through their own QA process, and sign off through the PI. This is exactly how custom SOP consulting engagements deliver SOPs — the consultant writes the template, the site adapts it. We are selling the template layer directly, not the consulting layer."
      }
    },
    {
      "@type": "Question",
      "name": "Are they aligned to ICH E6(R3)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. All 13 SOPs are written against the current ICH E6(R3) framework with explicit attention to the structural changes from R2 to R3 — risk-based monitoring language, expanded electronic records requirements, updated sponsor oversight obligations, and the broader quality management system expectations. Sites operating under R2-only language for sponsor and monitor expectations will find the R3 updates already incorporated."
      }
    },
    {
      "@type": "Question",
      "name": "Can sites buy individual SOPs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Each of the 13 SOPs is available individually at $29. Useful for sites that have mature libraries but need targeted updates — for example, consent (SOP-004) or IP accountability (SOP-006) as ICH E6(R3) changes those specific procedures."
      }
    }
  ]
};
---

<Site
  title="ICH E6(R3) SOP Templates — Purple Directive vs. Custom SOP Consulting"
  description="How Purple Directive's $249.99 13-SOP bundle compares to custom SOP consulting ($5K-$15K), QMS platforms ($10K-$100K+), and other template libraries. Built against ICH E6(R3), editable Word + PDF."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="prod-hero">
    <div class="container prod-hero-grid">
      <div>
        <div class="section-label">SOP Library Comparison · April 2026</div>
        <h1>ICH E6(R3) SOP Templates for Clinical Research Sites</h1>
        <p class="lede">
          How my $249.99 13-SOP bundle compares to custom SOP consulting ($5K–$15K),
          quality management system platforms ($10K–$100K+/year), and other template libraries.
          Every SOP is written against ICH E6(R3) and covers the seven 483 observation categories
          FDA BIMO inspections are currently citing.
        </p>
        <div class="cta-row">
          <a href="/sop-bundle/" class="btn-primary">See the SOP Bundle
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </div>
        <p class="hero-note">
          Or read the free <a href="/bimo-taxonomy/">FY2022–2024 BIMO 483 Observation Taxonomy</a> first —
          it shows exactly which site failures each SOP is designed to prevent.
        </p>
        <div class="facts">
          <span class="fact">13 SOPs</span>
          <span class="fact">11 companion forms</span>
          <span class="fact">125 pages</span>
          <span class="fact">$249.99 / $29 per SOP</span>
        </div>
      </div>
      <aside class="at-glance">
        <p class="at-glance-cap">At a glance</p>
        <ul>
          <li><strong>$249.99</strong> vs $5K–$15K consulting</li>
          <li><strong>13 SOPs</strong> + 11 companion forms</li>
          <li><strong>ICH E6(R3)</strong> aligned</li>
          <li><strong>Editable Word</strong> + PDF</li>
        </ul>
      </aside>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="section doc">
    <div class="container">
    <div class="doc-block" style="border-top:none;padding-top:0">
    <h2>How SOP options compare</h2>
    <div class="compare-table-wrap">
      <table class="compare-table">
        <thead>
          <tr>
            <th scope="col">Option</th>
            <th scope="col">Price</th>
            <th scope="col">Delivery</th>
            <th scope="col">Custom to your site</th>
            <th scope="col">ICH E6(R3) current</th>
          </tr>
        </thead>
        <tbody>
          <tr class="compare-row-highlight">
            <td><strong>Purple Directive Bundle</strong></td>
            <td><strong>$249.99</strong></td>
            <td>Instant download</td>
            <td>Template (site adapts)</td>
            <td>Yes</td>
          </tr>
          <tr>
            <td>Purple Directive — individual SOP</td>
            <td>$29</td>
            <td>Instant download</td>
            <td>Template (site adapts)</td>
            <td>Yes</td>
          </tr>
          <tr>
            <td>Custom SOP consulting (Advarra, Halloran, WCG)</td>
            <td>$5,000–$15,000</td>
            <td>4–8 weeks</td>
            <td>Yes (custom-written)</td>
            <td>Yes</td>
          </tr>
          <tr>
            <td>QMS platform (Veeva Vault QMS, MasterControl)</td>
            <td>$10,000–$100,000+/yr</td>
            <td>Onboarding 4–12 weeks</td>
            <td>Platform + templates</td>
            <td>Varies</td>
          </tr>
          <tr>
            <td>Free SOP templates (ACRP, academic sites)</td>
            <td>$0</td>
            <td>Instant</td>
            <td>Generic</td>
            <td>Often R2-era</td>
          </tr>
          <tr>
            <td>Write from scratch in-house</td>
            <td>50+ hours staff time</td>
            <td>Weeks–months</td>
            <td>Yes</td>
            <td>If you do it right</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="compare-note">
      <em>Consulting prices are industry ranges — firms rarely publish fixed prices for SOP-library engagements. Platform pricing is subscription-based with tiered feature sets.</em>
    </p>
    </div>

    <!-- The positioning -->
    <div class="doc-block">
    <h2>Where Purple Directive sits in the SOP market</h2>
    <div class="why-now-grid">
      <div class="why-now-card">
        <h3>20–60× cheaper than custom consulting</h3>
        <p>
          Custom SOP consulting from Advarra, Halloran, WCG, and similar firms runs $5,000 to $15,000 for a full 12-document library. Purple Directive bundle is $249.99 — because we're selling the template layer, not the consulting engagement that adapts the templates to your specific site.
        </p>
      </div>
      <div class="why-now-card">
        <h3>A fraction of QMS platform cost</h3>
        <p>
          Veeva Vault QMS, MasterControl, and similar document-controlled quality management platforms start at $10,000 per year and scale to six figures for multi-site deployments. They are the right choice for CROs and large sponsor networks. For an independent or small-network site, the overhead-to-value ratio is often wrong — and a $249.99 template library adapted to your existing document management process delivers R3-aligned compliance at 1% of the cost.
        </p>
      </div>
      <div class="why-now-card">
        <h3>R3-aligned, not R2-era</h3>
        <p>
          Free SOP templates from ACRP archives, older academic sites, and legacy compliance resources typically reference ICH E6(R2) language for monitoring, essential documents, and electronic records. Sponsors and monitors operating under R3 expect the updated language. The Purple Directive bundle is written directly against R3, with explicit attention to the R2-to-R3 structural changes.
        </p>
      </div>
      <div class="why-now-card">
        <h3>Mapped to FDA's enforcement patterns</h3>
        <p>
          The 13 SOPs in the bundle map directly to the seven observation categories in our <a href="/bimo-taxonomy/">FY2022–2024 BIMO 483 Observation Taxonomy</a>. That means each SOP is designed to address a specific failure mode FDA is currently citing: SOP-004 (Consent) for Part 50 observations, SOP-006 (IP) for IP accountability, SOP-008 (AE / Deviations) for 312.64(b) and protocol non-compliance, SOP-007 (Data Management) for 312.62 recordkeeping, SOP-002 (Essential Documents) for IRB communication. Not generic — targeted at the actual enforcement landscape.
        </p>
      </div>
    </div>
    </div>

    <!-- Not for -->
    <div class="doc-block">
    <h2>When a different option is the better fit</h2>
    <div class="why-now-grid">
      <div class="why-now-card">
        <h3>You need fully custom SOPs from scratch</h3>
        <p>
          If your site has unusual procedures (bespoke Phase I protocols, rare-disease trials with non-standard workflows, non-GCP investigator-initiated research), a custom SOP consulting engagement from Halloran, Advarra, or WCG at $5K–$15K will write documents built specifically for your operations. A template bundle is a starting point, not a bespoke deliverable — if your operations are unusual enough that the templates need substantial rewriting, custom consulting is the right spend.
        </p>
      </div>
      <div class="why-now-card">
        <h3>You need an integrated document-control platform</h3>
        <p>
          If your site needs electronic SOP version control, automated training assignments, audit-trail-backed revision history, and enforced routing — you need a QMS platform (Veeva, MasterControl, SimpleQMS, Greenlight Guru) at $10K+/year. Our SOPs integrate into any of those platforms as the document layer, but we don't replace the platform itself.
        </p>
      </div>
      <div class="why-now-card">
        <h3>You already have a mature SOP library</h3>
        <p>
          If you're a 10+ year site with an existing R2 library that just needs R3 updates, you probably don't need a full bundle. Individual SOPs at $29 each (e.g., just SOP-004 Consent and SOP-011 Remote Monitoring if those are the R2→R3 changes that hit you hardest) are the better spend.
        </p>
      </div>
    </div>
    </div>
    </div>
  </section>

  <!-- CTA -->
  <Testimonials product="sop" heading="What practitioners say" />

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="cta-tinted">
        <h2>Ready to review the bundle?</h2>
        <p>
          $249.99 full bundle · $29 per individual SOP · 125 pages · 13 ICH E6(R3)-aligned SOPs plus 11 companion forms · Editable Word and PDF.
        </p>
        <div class="cta-row" style="justify-content:center">
          <a href="/sop-bundle/" class="btn-primary">See the SOP Bundle
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </div>
        <p style="margin-top: 1rem; font-size: 0.9rem;">
          Or start with the free <a href="/bimo-taxonomy/">BIMO 483 Observation Taxonomy</a> —
          it shows the specific site failures each SOP is designed to prevent.
        </p>
      </div>
    </div>
  </section>

  <!-- Email capture -->
  <section class="section" style="padding-top:0">
    <div class="container" style="max-width:700px;margin:0 auto">
      <EmailCapture
        heading="Stay updated on ICH & FDA changes"
        subheading="Monthly practitioner notes on FDA enforcement patterns, ICH updates, and the operational intel that doesn't fit on a product page."
      />
    </div>
  </section>

</Site>
