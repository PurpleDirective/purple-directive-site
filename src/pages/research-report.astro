---
import Site from '../layouts/Site.astro';
import EmailCapture from '../components/EmailCapture.astro';

const aiWedge = [
  ['In healthcare, AI is wrong where it matters most', 'Independent 2026 testing found up to ~17% of AI-generated <em>medical</em> citations don\'t actually support the claim — and you can\'t tell which by reading it. I open and verify every source against the primary record.'],
  ['The facts move faster than the model', 'FDA approvals, label changes, and reimbursement codes shift constantly; one evaluation measured 29% accuracy on FDA boxed warnings. I check the current primary source as of your report date — not a training cutoff.'],
  ['It can\'t read what your decision rests on', 'The primary literature, payer policies, and competitor filings that actually drive the decision sit behind paywalls a public-web AI never opens. I do.'],
  ['You get a name, not a black box', 'The AI signs nothing and owns nothing. You get a credentialed clinical-research practitioner who stakes professional judgment on the conclusions — the layer that turns information into a decision you can defend.'],
];

const sections = [
  ['Executive Summary', 'The one-page version you send to your board, co-founder, or investor. Key findings, bottom-line recommendation, and the data that supports it. No filler.'],
  ['Market Landscape', 'Size, growth rate, regulatory context, reimbursement environment where applicable, and the forces actually moving the category right now — in plain language, not consulting-speak.'],
  ['Competitor Matrix', 'Direct and adjacent competitors mapped against the dimensions your decision depends on. Pricing, positioning, feature gaps, and recent moves that matter.'],
  ['Buyer Personas', 'Who actually signs the check, what their day-to-day pain is, what language they respond to, and what they already use and why they’d switch.'],
  ['Regulatory & Compliance Context', 'If your market touches FDA, EMA, HIPAA, 21 CFR Part 11, or ICH-GCP — these are documents we read for a living. This is the reason you hire a clinical professional instead of a generalist.'],
  ['Sourced Citations', 'Every claim is cited, primary sources where possible. Hand the report to a skeptical CFO, lawyer, or investor and they can verify any number themselves.'],
];
---
<Site
  title="48-Hour Healthcare Market Research Reports"
  description="Decision-grade healthcare and life-sciences market research, verified by a clinical-research practitioner against primary FDA, clinical-trial, and payer sources. Flat $750 fee, 48-hour turnaround. Written by Tyrian Murex."
>
  <section class="prod-hero">
    <div class="container">
      <a href="/#products" class="prod-back">&larr; All products</a>
      <div class="section-label">Research Report</div>
      <h1>Decision-grade market research, verified by a practitioner.</h1>
      <p class="lede">AI can draft a healthcare market report in minutes &mdash; and it will be confidently wrong: fabricated citations, stale FDA approvals, reimbursement details it can't actually read. I do the layer that makes it usable: every claim checked against primary FDA, clinical-trial, and payer sources, with my name on the conclusions. 48-hour turnaround &mdash; instead of $15,000 and three weeks from an agency.</p>
      <div class="price-row">
        <span class="price">$750</span>
        <span class="price-note">flat fee &middot; 48 hours &middot; 20&ndash;25pp PDF + 1-page executive summary + sources appendix</span>
      </div>
      <div class="cta-row">
        <a href="/buy/research-report?utm_source=direct&amp;utm_medium=research-report-hero" class="btn-primary">Order a report
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        <a href="/sample-report/" class="btn-ghost">Read a free sample</a>
      </div>
      <div class="facts">
        <span class="fact">20&ndash;25 page PDF</span>
        <span class="fact">48-hour turnaround</span>
        <span class="fact">Primary-source verified</span>
        <span class="fact">Practitioner-signed</span>
      </div>
      <p class="lede" style="font-size:.9rem;margin-top:1.2rem">After checkout you'll get an intake form and an optional 15-minute scoping call. See the depth first &mdash; read the <a href="/sample-report/" style="color:#cbb8ff;text-decoration:underline">public 1-page sample</a>, or <a href="/healthcare-market-research-pricing/" style="color:#cbb8ff;text-decoration:underline">how this compares</a> to other research firms.</p>
    </div>
  </section>

  <!-- The wedge: why a verified practitioner, not raw AI -->
  <section class="section" id="why-not-ai">
    <div class="container">
      <div class="section-label">Why not just run it through AI yourself?</div>
      <h2>Because in healthcare, "confidently wrong" is expensive.</h2>
      <p class="lede" style="max-width:46rem">Use the $20/month AI tools for a low-stakes scan, if you're already a domain expert, or when no real decision rides on the answer. This service is for the decisions where being wrong is expensive.</p>
      <div class="feat-grid">
        {aiWedge.map(([title, body]) => (
          <div class="feat"><h3>{title}</h3><p set:html={body}></p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="inside" style="padding-top:0">
    <div class="container">
      <div class="section-label">What's in it</div>
      <h2>Six sections. One decision.</h2>
      <p class="lede" style="max-width:46rem">Built to answer the question you're actually asking &mdash; is this market worth entering, and what does it take? Every section is sourced; nothing is hand-waved.</p>
      <div class="feat-grid">
        {sections.map(([title, body]) => (
          <div class="feat"><h3>{title}</h3><p>{body}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="how" style="padding-top:0">
    <div class="container">
      <div class="section-label">How it works</div>
      <h2>Submit Monday. Decide Wednesday.</h2>
      <div class="feat-grid" style="grid-template-columns:repeat(3,1fr)">
        <div class="feat"><h3>1 &middot; Order &amp; intake</h3><p>Pay the flat $750 fee. Checkout sends you a short intake form &mdash; the market and the question &mdash; plus an optional 15-minute scoping call if the brief needs clarification.</p></div>
        <div class="feat"><h3>2 &middot; We build it in 48 hours</h3><p>AI-augmented retrieval and first-draft synthesis; a practitioner applies the judgment and checks every claim against primary sources. You get the analyst output &mdash; the AI is in the basement, not the deliverable.</p></div>
        <div class="feat"><h3>3 &middot; Delivered to your inbox</h3><p>A 20&ndash;25 page PDF, a one-page executive summary, a sources appendix, and one round of clarifications. No revision spiral &mdash; the report is the product.</p></div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="section-label">Why this practitioner</div>
      <h2>A clinician living in the regulated world.</h2>
      <div class="feat-grid">
        <div class="feat"><h3>Practitioner-level clinical background</h3><p>Written by Tyrian Murex, a clinical research associate at a major US academic health system working on active FDA-regulated studies. When a report covers trials, site operations, CRO dynamics, or reimbursement, it isn't research done for the first time &mdash; it's the day job.</p></div>
        <div class="feat"><h3>ICH-GCP &amp; hands-on regulatory context</h3><p>FDA guidance, ICH E6(R3), 21 CFR Parts 11/50/56/312, and EMA publications are part of normal work &mdash; context a generalist freelancer would have to Google.</p></div>
        <div class="feat"><h3>Every claim verified against the primary record</h3><p>Each factual claim is opened and checked against a primary source as of your report date. You can hand the report to a skeptical CFO, lawyer, or investor and they can verify any number themselves.</p></div>
        <div class="feat"><h3>No revision theater</h3><p>The flat fee includes one clarification round for genuinely unclear asks. It doesn't include endless scope creep. Need a different angle? That's a new report &mdash; which keeps the service fast and the price honest.</p></div>
      </div>
    </div>
  </section>

  <section class="proof" id="proof">
    <div class="container">
      <span class="pl">Why it's trusted</span>
      <span class="pchip">Primary FDA / trial / payer sources</span>
      <span class="pchip">Signed by a practitioner</span>
      <span class="pchip">Every claim cited</span>
      <span class="pchip">48-hour turnaround</span>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq" style="padding-top:var(--sp-2xl)">
    <div class="container" style="max-width:760px;margin:0 auto">
      <div class="section-label">Questions</div>
      <h2 style="margin-bottom:var(--sp-lg)">Before you order.</h2>
      <details class="faq-item"><summary>Is $750 really the full price?</summary><p>Yes. Flat fee, taken at order. The only reason it might be more is if your scope is larger than one report &mdash; in which case we tell you before you pay, not after.</p></details>
      <details class="faq-item"><summary>What if I need non-healthcare research?</summary><p>We focus on healthcare, life sciences, and clinical operations because that's where the credentials create real value. Adjacent briefs (health-tech, medical device, digital health, pharma ops, CRO services) are in scope. A crypto project or a horizontal SaaS is not &mdash; there are better-fit freelancers for that.</p></details>
      <details class="faq-item"><summary>Can I see a sample report?</summary><p>Yes. <a href="/sample-report">Read the public 1-page sample</a> &mdash; a pattern read of FDA Form 483 observations at US oncology trial sites with primary-source citations. It shows the analytical depth and citation discipline a full report delivers.</p></details>
      <details class="faq-item"><summary>What if it's not useful?</summary><p>If the report materially fails the brief &mdash; the scope we agreed at intake wasn't delivered &mdash; we rework it or refund. That's not the same as wanting a different conclusion, which is a scope disagreement, not a quality issue.</p></details>
      <details class="faq-item"><summary>Do you sign NDAs?</summary><p>Yes. Mutual NDA available on request before intake. All client information stays confidential &mdash; your research is not reused for other clients.</p></details>
      <details class="faq-item"><summary>Can I talk to you first?</summary><p>Yes. The order flow includes an optional 15-minute scoping call before research begins. Prefer to talk first? <a href="https://calendly.com/nexrial/healthcare-market-research-scoping-call" target="_blank" rel="noopener">Book a call</a>.</p></details>
    </div>
  </section>

  <!-- Lead magnet + email capture -->
  <section class="section" style="padding-top:0">
    <div class="container" style="max-width:760px;margin:0 auto">
      <div class="leadbox">
        <span class="lead-kicker">Free to read first</span>
        <h3>FY2022&ndash;2024 BIMO 483 Observation Taxonomy</h3>
        <p>See the depth standard before you commission a custom report. Seven observation categories, verified primary-source citations, FDA BIMO base rates. Free, no signup.</p>
        <a href="/bimo-taxonomy/" class="btn-primary">Read the taxonomy &rarr;</a>
      </div>
      <EmailCapture
        source="research-report"
        heading="Or follow the practitioner notes"
        subheading="Monthly notes from a practitioner working in FDA-regulated oncology studies. No pitch — just specific, cited observations from inside clinical research operations."
      />
    </div>
  </section>

  <!-- Service Terms — legal baseline (AI disclosure, refund, confidentiality, capacity) -->
  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="section-label">Service terms</div>
      <h2>How the service works, in writing.</h2>
      <div class="feat-grid">
        <div class="feat"><h3>How AI is used in this service</h3><p>This research is produced with AI assistance. AI tools handle the heavy retrieval pass, source aggregation, and first-draft synthesis. A human reviews every claim, verifies primary sources, applies professional judgment, structures the narrative, and signs off on the deliverable. You are paying for the judgment layer. This disclosure is provided in good faith and in alignment with FTC AI guidance and EU AI Act Article 50 transparency principles.</p></div>
        <div class="feat"><h3>What this report is &mdash; and is not</h3><p>This is an informational market research deliverable for your internal decision-making. It is <b>not</b> legal, medical, financial, or investment advice, and not a regulatory submission. It is not a substitute for your own professional judgment, legal counsel, clinical expertise, or due diligence. You remain responsible for the decisions you make based on the report.</p></div>
        <div class="feat"><h3>Source verification commitment</h3><p>Every factual claim is cited to a primary source where one exists. You can independently verify any number, statistic, or assertion. Find an error in citation or fact and we correct and re-issue the report at no additional charge.</p></div>
        <div class="feat"><h3>Refund and rework policy</h3><p>If the delivered report materially fails the scope agreed at intake, we rework it at no additional charge or refund the full fee, your choice. This does not cover scope disagreements (a different angle or additional analysis), which are handled as new engagements. The flat fee includes one round of clarification questions.</p></div>
        <div class="feat"><h3>Confidentiality and data handling</h3><p>A mutual NDA is available on request before intake. Information you share is used only to produce your report &mdash; not reused for other clients, not shared with third parties, and not used to train any AI model. Working files are retained for 90 days post-delivery for clarification, then deleted unless you request earlier deletion.</p></div>
        <div class="feat"><h3>Independent professional capacity</h3><p>This service is offered by Tyrian Murex in a personal, independent capacity. It is not affiliated with, endorsed by, or representative of any employer or other institution. References to clinical research experience reflect professional background and do not imply institutional sponsorship of this work.</p></div>
      </div>
    </div>
  </section>

  <section class="cta-tail">
    <div class="container">
      <h2>The agency quote was $15,000.</h2>
      <p>Get decision-grade research for $750, in two days &mdash; verified against the primary record, with someone's name on the conclusions.</p>
      <div class="cta-row">
        <a href="/buy/research-report?utm_source=direct&amp;utm_medium=research-report-cta" class="btn-primary">Order a report &mdash; $750</a>
        <a href="https://calendly.com/nexrial/healthcare-market-research-scoping-call" target="_blank" rel="noopener" class="btn-ghost">Book a 15-minute call</a>
      </div>
    </div>
  </section>
</Site>

<style>
  .leadbox{background:var(--bg-tinted);border:1px solid var(--border);border-radius:14px;padding:var(--sp-lg);margin-bottom:var(--sp-lg)}
  .leadbox .lead-kicker{font-family:var(--font-mono);font-size:.62rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--purple-primary)}
  .leadbox h3{font-size:1.1rem;font-weight:700;margin:.5rem 0 .4rem;color:var(--text-primary)}
  .leadbox p{font-size:.92rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1.1rem;max-width:52rem}

  .faq-item{border-bottom:1px solid var(--border)}
  .faq-item summary{padding:var(--sp-md) 0;font-size:.92rem;font-weight:600;color:var(--text-primary);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:var(--sp-md)}
  .faq-item summary::-webkit-details-marker{display:none}
  .faq-item summary::after{content:"+";font-size:1.1rem;color:var(--text-muted);flex-shrink:0;transition:transform .2s}
  .faq-item[open] summary::after{content:"\2212"}
  .faq-item p{font-size:.88rem;color:var(--text-secondary);line-height:1.65;padding-bottom:var(--sp-md);margin:0}
  .faq-item a{color:var(--purple-primary);font-weight:500}
</style>
