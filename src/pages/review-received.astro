---
import Base from '../layouts/Base.astro';
---

<Base title="Review received" description="Thank you — your review has been received.">
  <section class="section hero">
    <h1>Thank you — review <span class="accent">received</span></h1>
    <p class="subtitle">
      We read every one. If you OK'd publishing, we'll review it and may feature it on the site.
      It genuinely helps shape what we build next.
    </p>
    <div style="margin-top: 2rem; text-align: center;">
      <a href="/" class="back-btn">Back to Home</a>
    </div>
  </section>
</Base>

<style>
  .back-btn {
    display: inline-block;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.7rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .back-btn:hover {
    border-color: var(--purple-primary);
    color: var(--purple-primary);
  }
</style>
