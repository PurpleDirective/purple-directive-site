---
import Base from '../layouts/Base.astro';
---

<Base title="Intake received" description="Your Healthcare Market Research intake has been received.">
  <section class="section hero">
    <h1>Intake <span class="accent">received</span></h1>
    <p class="subtitle">
      Thank you. I'll review your intake within 12 hours and confirm scope before starting research.
      If anything is unclear, I'll send a short clarification email or schedule a 15-minute call.
    </p>
    <div style="margin-top: 2rem; text-align: center;">
      <a href="/" class="back-btn">Back to Home</a>
    </div>
  </section>
</Base>

<style>
  .back-btn {
    display: inline-block;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.7rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .back-btn:hover {
    border-color: var(--purple-primary);
    color: var(--purple-primary);
  }
</style>
