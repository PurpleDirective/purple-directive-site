---
import Site from '../layouts/Site.astro';
---

<Site title="Feedback received" description="Thank you — your feedback has been received.">
  <section class="section hero">
    <h1>Got it — feedback <span class="accent">received</span></h1>
    <p class="subtitle">
      It goes straight to the internal team. If you left an email, we'll reply;
      if you didn't, it still gets read — every entry does.
    </p>
    <div style="margin-top: 2rem; text-align: center;">
      <a href="/" class="back-btn">Back to Home</a>
    </div>
  </section>
</Site>

<style>
  .back-btn {
    display: inline-block;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.7rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .back-btn:hover {
    border-color: var(--purple-primary);
    color: var(--purple-primary);
  }
</style>
