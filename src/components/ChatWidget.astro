---
/**
 * Purple Directive assistant — "The Standard Console" (command-palette).
 * Self-contained. Posts to same-origin /api/chat (Cloudflare Pages Function).
 * NO PHI — enforced by the footer note and the backend system prompt.
 */
---
<style is:global>
  #pds,#pds *{box-sizing:border-box}
  #pds{--bg:#1b0f3d;--bg2:#140a2c;--card:#1f1247;--line:rgba(182,155,255,.16);--line2:rgba(182,155,255,.32);
    --ink:#f1ecff;--ink2:#cbc4e6;--mut:#9b92bd;--acc:#b69bff;--acc2:#7C3AED;--ok:#54e6a8;
    --mono:'IBM Plex Mono','SF Mono',ui-monospace,monospace;
    --sans:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}

  /* Launcher — a command bar, not a bubble */
  #pds-open{position:fixed;right:24px;bottom:24px;z-index:2147483000;display:inline-flex;align-items:center;gap:10px;
    padding:11px 13px 11px 14px;min-width:230px;background:linear-gradient(160deg,var(--bg),var(--bg2));
    border:1px solid var(--line2);border-radius:12px;color:var(--ink2);cursor:pointer;font-family:var(--sans);font-size:13px;
    box-shadow:0 12px 34px rgba(14,8,32,.5);transition:transform .15s,box-shadow .15s,border-color .15s}
  #pds-open:hover{transform:translateY(-2px);border-color:var(--acc);box-shadow:0 16px 42px rgba(14,8,32,.62)}
  #pds-open .gl{width:20px;height:20px;flex:0 0 auto}
  #pds-open .lbl{flex:1;text-align:left}
  #pds-open .cur{width:2px;height:17px;background:var(--acc);margin-left:4px;animation:pdsbl 1.1s steps(1) infinite}

  /* Overlay + palette */
  #pds-ov{position:fixed;inset:0;z-index:2147483001;display:none;align-items:flex-start;justify-content:center;
    background:rgba(9,5,20,.40);backdrop-filter:blur(2px);padding:12vh 16px 16px}
  #pds.on #pds-ov{display:flex}
  #pds.on #pds-open{opacity:0;pointer-events:none}
  #pds-pal{width:clamp(400px,92vw,512px);max-height:74vh;background:linear-gradient(180deg,var(--bg),var(--bg2));
    border:1px solid var(--line2);border-radius:18px;box-shadow:0 40px 100px rgba(6,3,16,.7);display:flex;flex-direction:column;
    overflow:hidden;transform:translateY(-8px) scale(.985);opacity:0;animation:pdsin .22s cubic-bezier(.2,.8,.2,1) forwards}
  @keyframes pdsin{to{transform:none;opacity:1}}

  /* Query row */
  #pds-q{display:flex;align-items:center;gap:11px;padding:15px 18px}
  #pds-q .mark{width:24px;height:24px;flex:0 0 auto}
  #pds-in{flex:1;background:transparent;border:0;outline:none;color:var(--ink);font-family:var(--sans);font-size:16px;line-height:1.3}
  #pds-in::placeholder{color:var(--mut)}
  #pds-q .esc{background:transparent;border:0;color:var(--mut);font-size:19px;line-height:1;cursor:pointer;padding:2px 4px;flex:0 0 auto}
  #pds-q .esc:hover{color:var(--acc)}
  #pds-hair{height:1px;background:var(--line);margin:0 0}

  /* Body: chips (empty state) + answers */
  #pds-body{overflow-y:auto;padding:14px 20px 4px;scrollbar-width:thin;scrollbar-color:var(--line2) transparent}
  #pds-body::-webkit-scrollbar{width:8px}#pds-body::-webkit-scrollbar-thumb{background:var(--line2);border-radius:8px}
  #pds-chips .ch-lbl{font-family:var(--mono);font-size:10px;letter-spacing:.16em;color:var(--mut);margin:0 0 11px}
  #pds-chips .ch-wrap{display:flex;flex-direction:column;gap:7px;margin-bottom:4px}
  .pds-chip{width:100%;font-family:var(--sans);font-size:13.5px;color:var(--ink2);background:rgba(124,58,237,.07);border:1px solid var(--line);
    border-radius:10px;padding:11px 14px;cursor:pointer;text-align:left;transition:background .12s,border-color .12s}
  .pds-chip:hover{background:rgba(124,58,237,.18);border-color:var(--acc);color:var(--ink)}

  .pds-qa{margin-bottom:18px}
  .pds-ask{font-family:var(--mono);font-size:11px;letter-spacing:.04em;color:var(--acc);margin-bottom:8px}
  .pds-ans{font-family:var(--sans);font-size:14px;line-height:1.6;color:var(--ink2);white-space:pre-wrap;word-wrap:break-word}
  .pds-ans a{color:var(--acc);text-decoration:underline;text-underline-offset:2px}
  .pds-caret{display:inline-block;width:8px;height:14px;background:var(--acc);vertical-align:-2px;animation:pdsbl 1.1s steps(1) infinite}
  @keyframes pdsbl{0%,50%{opacity:1}51%,100%{opacity:0}}

  /* Footer action rail */
  #pds-foot{border-top:1px solid var(--line);padding:12px 20px;display:flex;align-items:center;gap:18px}
  #pds-foot a{font-family:var(--sans);font-size:12.5px;color:var(--ink2);text-decoration:none;white-space:nowrap;display:inline-flex;align-items:center;gap:6px}
  #pds-foot a:hover{color:var(--acc)}
  #pds-foot .note{font-family:var(--mono);font-size:9.5px;letter-spacing:.04em;color:var(--mut);margin-top:1px}
  @media(max-width:560px){#pds-foot .note{display:none}#pds-open{min-width:0}#pds-open .lbl{display:none}}
</style>
<div id="pds" role="region" aria-label="Purple Directive assistant">
  <button id="pds-open" aria-label="Ask Purple (Command-K)">
    <img class="gl" src="/pd-mark-grad.svg" alt="" aria-hidden="true"/>
    <span class="lbl">Ask Purple</span><span class="cur" aria-hidden="true"></span>
  </button>
  <div id="pds-ov" role="dialog" aria-modal="true" aria-label="Purple Directive assistant">
    <div id="pds-pal">
      <div id="pds-q">
        <img class="mark" src="/pd-mark-grad.svg" alt="" aria-hidden="true"/>
        <input id="pds-in" type="text" placeholder="Ask Purple anything…" aria-label="Ask Purple" autocomplete="off"/>
        <button class="esc" id="pds-esc" type="button" aria-label="Close">&times;</button>
      </div>
      <div id="pds-hair"></div>
      <div id="pds-body">
        <div id="pds-chips">
          <div class="ch-lbl">TRY ASKING</div>
          <div class="ch-wrap"></div>
        </div>
      </div>
      <div id="pds-foot">
        <a href="mailto:info@purpledirective.com?subject=Scoping%20call">Book a scoping call</a>
        <a href="https://calendly.com/nexrial/demo" target="_blank" rel="noopener">See a Nexrial demo</a>
      </div>
    </div>
  </div>
</div>
<script is:inline>
(function(){
  var root=document.getElementById('pds'),opener=document.getElementById('pds-open'),ov=document.getElementById('pds-ov'),
      input=document.getElementById('pds-in'),body=document.getElementById('pds-body'),chips=document.getElementById('pds-chips'),
      chwrap=chips.querySelector('.ch-wrap'),esc=document.getElementById('pds-esc');
  var history=[],busy=false;
  var SEED=["How much is the SOP bundle?","Is Nexrial designed for 21 CFR Part 11?",
            "How fast is a research report, and what's in it?","Can you set up a brand-new research site?",
            "What does consulting actually include?"];
  SEED.forEach(function(q){var b=document.createElement('button');b.className='pds-chip';b.textContent=q;
    b.addEventListener('click',function(){ask(q);});chwrap.appendChild(b);});
  function esch(s){return s.replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];});}
  function linkify(s){return esch(s).replace(/(https?:\/\/[^\s)]+)|(\/[a-z0-9\-\/]+)/gi,function(m){
    return '<a href="'+m+'" target="_blank" rel="noopener">'+m+'</a>';});}
  function open(seed){root.classList.add('on');setTimeout(function(){input.focus();if(seed){input.value=seed;input.dispatchEvent(new Event('input',{bubbles:true}));}},60);}
  function shut(){root.classList.remove('on');}
  opener.addEventListener('click',function(){open();});
  opener.addEventListener('keydown',function(e){if(e.key.length===1&&!e.metaKey&&!e.ctrlKey&&!e.altKey){e.preventDefault();open(e.key);}});
  esc.addEventListener('click',shut);
  ov.addEventListener('mousedown',function(e){if(e.target===ov)shut();});
  document.addEventListener('keydown',function(e){
    if((e.metaKey||e.ctrlKey)&&e.key.toLowerCase()==='k'){e.preventDefault();root.classList.contains('on')?shut():open();}
    else if(e.key==='Escape'&&root.classList.contains('on')){shut();}});
  input.addEventListener('keydown',function(e){if(e.key==='Enter'){e.preventDefault();var v=input.value.trim();if(v)ask(v);}});
  function ask(q){
    if(busy)return;chips.style.display='none';input.value='';busy=true;
    var qa=document.createElement('div');qa.className='pds-qa';
    qa.innerHTML='<div class="pds-ask">&rsaquo; '+esch(q)+'</div><div class="pds-ans"><span class="pds-caret"></span></div>';
    body.appendChild(qa);body.scrollTop=body.scrollHeight;
    var ansEl=qa.querySelector('.pds-ans');
    history.push({role:'user',content:q});
    fetch('/api/chat',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({messages:history})})
      .then(function(r){return r.json().catch(function(){return {};});})
      .then(function(d){var reply=(d&&d.reply)||"Sorry — something went wrong. Please email info@purpledirective.com.";
        ansEl.innerHTML=linkify(reply);history.push({role:'assistant',content:reply});body.scrollTop=body.scrollHeight;})
      .catch(function(){ansEl.textContent="I couldn't reach the assistant. Please email info@purpledirective.com.";})
      .finally(function(){busy=false;input.focus();});
  }
})();
</script>
