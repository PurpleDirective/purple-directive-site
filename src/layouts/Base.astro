---
import { social } from '../data/social';

interface Props {
  title: string;
  description?: string;
  activePage?: string;
  ogImage?: string;
}

const { title, description = "Compliance-grade software and operations consulting for clinical research sites and CROs.", activePage = "", ogImage = "/og-image.png" } = Astro.props;
const fullTitle = title === "Home" ? "PurpleDirective" : `${title} — PurpleDirective`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#6B4C9A" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="192x192" href="/favicon-192.png" />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="PurpleDirective" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content={social.x.handle} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

  <title>{fullTitle}</title>
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <nav>
    <div class="container">
      <a href="/" class="logo">
        <svg class="logo-mark" viewBox="0 0 100 120" aria-hidden="true">
          <defs>
            <linearGradient id="navGrad" x1="30%" y1="0%" x2="70%" y2="100%">
              <stop offset="0%" stop-color="#b07ce8"/>
              <stop offset="100%" stop-color="#7a4db5"/>
            </linearGradient>
          </defs>
          <path d="M 26,96 L 26,16 C 26,6 76,6 76,50 C 76,80 58,94 44,87 C 33,80 30,70 36,62 C 40,55 50,53 56,53" fill="none" stroke="url(#navGrad)" stroke-width="13" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="logo-text">Purple<span>Directive</span></span>
      </a>

      <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">&#9776;</button>
      <ul class="links" id="nav-links">
        <li><a href="/#products" class:list={[{ active: activePage === "products" }]}>Products</a></li>
        <li><a href="/hire" class:list={[{ active: activePage === "hire" }]}>Services</a></li>
        <li><a href="/blog" class:list={[{ active: activePage === "blog" }]}>Blog</a></li>
        <li><a href="/about" class:list={[{ active: activePage === "about" }]}>About</a></li>
      </ul>
      <a href="/sop-bundle" class="nav-cta">Get the SOPs</a>
    </div>
  </nav>

  <main id="main" class="container">
    <slot />
  </main>

  <footer>
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col footer-brand">
          <a href="/" class="footer-logo">
            <svg class="footer-logo-mark" viewBox="0 0 100 120" aria-hidden="true">
              <path d="M 26,96 L 26,16 C 26,6 76,6 76,50 C 76,80 58,94 44,87 C 33,80 30,70 36,62 C 40,55 50,53 56,53" fill="none" stroke="#5B21B6" stroke-width="13" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="logo-text">Purple<span>Directive</span></span>
          </a>
          <p class="footer-tagline">Compliance-grade software and operations consulting for clinical research sites and CROs.</p>
        </div>

        <div class="footer-col">
          <h4>Products</h4>
          <ul>
            <li><a href="/sop-bundle">SOP Template Bundle</a></li>
            <li><a href="/#products">Nexrial CTMS</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Company</h4>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/hire">Services</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="mailto:info@purpledirective.com">Contact</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Connect</h4>
          <ul>
            <li><a href={social.linkedin.url} target="_blank" rel="noopener">LinkedIn</a></li>
            <li><a href={social.github.url} target="_blank" rel="noopener">GitHub</a></li>
            <li><a href={social.x.url} target="_blank" rel="noopener">X (Twitter)</a></li>
            <li><a href={social.reddit.url} target="_blank" rel="noopener">Reddit</a></li>
          </ul>
        </div>
      </div>

      <div class="footer-bottom">
        <div class="footer-legal">
          <span>&copy; {new Date().getFullYear()} Purple Directive LLC. All rights reserved.</span>
          <span class="footer-sep">&middot;</span>
          <a href="/privacy">Privacy Policy</a>
          <span class="footer-sep">&middot;</span>
          <a href="/terms">Terms of Service</a>
        </div>
        <p class="footer-disclaimer">
          Purple Directive LLC provides software, templates, and consulting services for informational and operational purposes only. Our products and services do not constitute legal, regulatory, or medical advice. SOP templates are customizable starting points and must be reviewed, adapted, and validated against your institution's specific policies, applicable regulations (including ICH E6(R2/R3), 21 CFR Parts 11/50/56/312, and 45 CFR Part 46), IRB requirements, and sponsor protocols before implementation. Purple Directive LLC assumes no liability for the use or misuse of any product or service.
        </p>
        <p class="footer-confidentiality">
          All client engagements are subject to confidentiality obligations. Protected health information (PHI) and personally identifiable information (PII) are handled in accordance with HIPAA Privacy and Security Rules. Purple Directive does not store, transmit, or process PHI through its public-facing products.
        </p>
      </div>
    </div>
  </footer>

  <script>
    // Nav toggle
    const toggle = document.getElementById('nav-toggle');
    const links = document.getElementById('nav-links');
    toggle?.addEventListener('click', () => {
      const open = links?.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(!!open));
    });
    links?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => links.classList.remove('open'));
    });
  </script>
  <!-- Cloudflare Web Analytics -->
  <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "be7494dd3df347c1b626566b5b386d91"}'></script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
