---
import { social } from '../data/social';

interface Props {
  title: string;
  description?: string;
  activePage?: string;
  ogImage?: string;
}

const { title, description = "Sovereign AI Agent Organization Framework", activePage = "", ogImage = "/og-image.png" } = Astro.props;
const fullTitle = title === "Home" ? "PurpleDirective" : `${title} — PurpleDirective`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#9b72cf" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="PurpleDirective" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content={social.x.handle} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

  <title>{fullTitle}</title>
</head>
<body>
  <nav>
    <div class="container">
      <a href="/" class="logo">
        <svg class="logo-mark" viewBox="0 0 100 120" aria-hidden="true">
          <defs>
            <linearGradient id="navGrad" x1="30%" y1="0%" x2="70%" y2="100%">
              <stop offset="0%" stop-color="#b07ce8"/>
              <stop offset="100%" stop-color="#7a4db5"/>
            </linearGradient>
          </defs>
          <path d="M 26,96 L 26,16 C 26,6 76,6 76,50 C 76,80 58,94 44,87 C 33,80 30,70 36,62 C 40,55 50,53 56,53" fill="none" stroke="url(#navGrad)" stroke-width="13" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        purple<span>directive</span><em>violet</em>
      </a>
      <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">&#9776;</button>
      <ul class="links" id="nav-links">
        <li><a href="/projects" class:list={[{ active: activePage === "projects" }]}>Projects</a></li>
        <li><a href="/blog" class:list={[{ active: activePage === "blog" }]}>Blog</a></li>
        <li><a href="/about" class:list={[{ active: activePage === "about" }]}>About</a></li>
        <li><a href={social.github.url} target="_blank" rel="noopener">GitHub</a></li>
        <li class="nav-divider"></li>
        <li><button class="nav-tool bionic-btn" id="bionic-toggle" title="Bionic Reading: ON" aria-pressed="true">Aa</button></li>
      </ul>
    </div>
  </nav>

  <main class="container">
    <slot />
  </main>

  <footer>
    <div class="container">
      <span class="motto">Keep Evolving. Keep Improving. Keep Keen.</span>
      <ul class="links">
        <li><a href={social.github.url} target="_blank" rel="noopener">GitHub</a></li>
        <li><a href={social.x.url} target="_blank" rel="noopener">X</a></li>
        <li><a href={social.reddit.url} target="_blank" rel="noopener">Reddit</a></li>
      </ul>
    </div>
  </footer>

  <script>
    // Nav toggle
    const toggle = document.getElementById('nav-toggle');
    const links = document.getElementById('nav-links');
    toggle?.addEventListener('click', () => {
      const open = links?.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(!!open));
    });
    links?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => links.classList.remove('open'));
    });

    // Bionic reading
    const BIONIC_KEY = 'pd-bionic';
    const SKIP_TAGS = new Set(['CODE', 'PRE', 'SCRIPT', 'STYLE', 'H1', 'H2', 'H3', 'H4', 'H5', 'H6', 'A', 'BUTTON']);
    let originalHTML: string | null = null;

    function bionicWord(word: string): string {
      if (word.length <= 1) return word;
      const mid = Math.ceil(word.length / 2);
      return `<b>${word.slice(0, mid)}</b>${word.slice(mid)}`;
    }

    function hasSkipAncestor(node: Node, root: Node): boolean {
      let el = node.parentElement;
      while (el && el !== root) {
        if (SKIP_TAGS.has(el.tagName)) return true;
        el = el.parentElement;
      }
      return false;
    }

    function applyBionic(root: HTMLElement) {
      if (!originalHTML) originalHTML = root.innerHTML;
      const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
      const textNodes: Text[] = [];
      let n: Text | null;
      while ((n = walker.nextNode() as Text | null)) {
        if (n.textContent?.trim() && !hasSkipAncestor(n, root)) {
          textNodes.push(n);
        }
      }
      textNodes.forEach(node => {
        const frag = document.createDocumentFragment();
        node.textContent!.split(/(\s+)/).forEach(part => {
          if (/^\s+$/.test(part)) {
            frag.appendChild(document.createTextNode(part));
          } else if (part) {
            const span = document.createElement('span');
            span.innerHTML = bionicWord(part);
            frag.appendChild(span);
          }
        });
        node.parentNode?.replaceChild(frag, node);
      });
    }

    function removeBionic(root: HTMLElement) {
      if (originalHTML !== null) root.innerHTML = originalHTML;
    }

    function setBionic(enabled: boolean) {
      const main = document.querySelector('main') as HTMLElement | null;
      const btn = document.getElementById('bionic-toggle') as HTMLButtonElement | null;
      if (!main || !btn) return;
      if (enabled) {
        applyBionic(main);
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        btn.title = 'Bionic Reading: ON';
      } else {
        removeBionic(main);
        btn.classList.remove('active');
        btn.setAttribute('aria-pressed', 'false');
        btn.title = 'Bionic Reading: OFF';
      }
      localStorage.setItem(BIONIC_KEY, enabled ? '1' : '0');
    }

    // Init: default ON unless user explicitly turned it off
    const saved = localStorage.getItem(BIONIC_KEY);
    const startEnabled = saved !== '0';
    setBionic(startEnabled);

    document.getElementById('bionic-toggle')?.addEventListener('click', () => {
      const current = localStorage.getItem(BIONIC_KEY) !== '0';
      setBionic(!current);
    });
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
