---
interface Props {
  title: string;
  description?: string;
  activePage?: string;
}

const { title, description = "Sovereign AI Agent Organization Framework", activePage = "" } = Astro.props;
const fullTitle = title === "Home" ? "PurpleDirective" : `${title} — PurpleDirective`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#9b72cf" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{fullTitle}</title>
</head>
<body>
  <nav>
    <div class="container">
      <a href="/" class="logo">purple<span>directive</span></a>
      <ul class="links">
        <li><a href="/projects" class:list={[{ active: activePage === "projects" }]}>Projects</a></li>
        <li><a href="/blog" class:list={[{ active: activePage === "blog" }]}>Blog</a></li>
        <li><a href="/about" class:list={[{ active: activePage === "about" }]}>About</a></li>
        <li><a href="https://github.com/PurpleDirective" target="_blank" rel="noopener">GitHub</a></li>
        <li class="nav-divider"></li>
        <li><a href="https://chat.purpledirective.com" target="_blank" rel="noopener" class="nav-tool" title="AI Chat">Chat</a></li>
        <li><a href="https://dash.purpledirective.com" target="_blank" rel="noopener" class="nav-tool" title="Private Dashboard">Dash</a></li>
      </ul>
    </div>
  </nav>

  <main class="container">
    <slot />
  </main>

  <footer>
    <div class="container">
      <span class="motto">Keep Evolving. Keep Improving. Keep Keen.</span>
      <ul class="links">
        <li><a href="https://github.com/PurpleDirective" target="_blank" rel="noopener">GitHub</a></li>
        <li><a href="https://reddit.com/u/PurpleDirective" target="_blank" rel="noopener">Reddit</a></li>
      </ul>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
